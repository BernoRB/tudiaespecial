<!DOCTYPE html>
<html lang="es-AR">
<head>
<%- include('partials/meta-tags', {
  title: "Pago · TuDiaEspecial",
  description: "Seleccioná tu método de pago para tu invitación digital. MercadoPago o transferencia bancaria. Servicio en Argentina.",
  keywords: "pago invitación digital, MercadoPago, transferencia bancaria, Argentina",
  url: "https://tudiaespecial.com/pago",
  type: "website"
}) %>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <nav>
    <div class="nav-logo">TuDia<span>Especial</span></div>
  </nav>

  <section style="padding-top:120px;padding-bottom:80px;background:var(--warm-white);">
    <div class="section-header" style="max-width:720px;margin:0 auto 32px;">
      <span class="section-label">Pago</span>
      <h2 class="section-title">¡Todo casi listo!</h2>
      <p class="section-sub">Aboná la seña y comenzaremos a trabajar en tu invitación.</p>
    </div>

    <div style="max-width:640px;margin:0 auto;background:var(--offwhite);padding:28px 22px;border-radius:4px;border:1px solid var(--border);box-shadow:var(--shadow-soft);font-size:0.9rem;color:var(--muted);margin-bottom:24px;">
      <p>Tipo de evento: <strong style="color:var(--ink);"><%= order.category %></strong></p>
      <p>Plantilla elegida: <strong style="color:var(--ink);"><%= order.template_key %></strong></p>
      <p>Te vamos a contactar a: <strong style="color:var(--ink);"><%= order.customer_email %></strong> · <strong style="color:var(--ink);"><%= order.customer_whatsapp %></strong></p>
    </div>

    <div style="max-width:640px;margin:0 auto;background:var(--offwhite);padding:10px 22px;border-radius:4px;border:1px solid var(--border);box-shadow:var(--shadow-soft);margin-bottom:0px;">
      <p style="font-size:1.1rem;color:var(--ink);margin-bottom:8px;">Seña: <strong style="font-size:1.3rem;color:var(--gold);">$14.500</strong></p>
    </div>

    <div style="max-width:640px;margin:0 auto;display:flex;flex-direction:column;gap:16px;">
      <a href="https://mpago.la/1XyA3YJ" class="plan-cta" style="text-align:center;text-decoration:none;">
        Pagar con MercadoPago
      </a>

      <div>
        <button type="button" onclick="toggleTransferencia()" style="width:100%;padding:12px 16px;background:var(--offwhite);border:1px solid var(--border);border-radius:4px;font-size:0.9rem;font-family:'Jost',sans-serif;color:var(--ink-soft);cursor:pointer;">
          PAGAR POR TRANSFERENCIA (5% OFF)
        </button>
        <div id="transferencia-details" style="display:none;margin-top:16px;padding:20px;background:rgba(212,175,55,0.1);border-radius:8px;border:1px solid rgba(212,175,55,0.2);">
          <p style="font-size:0.95rem;color:var(--ink);margin-bottom:12px;"><strong>Banco:</strong> GALICIA</p>
          <p style="font-size:0.95rem;color:var(--ink);margin-bottom:12px;"><strong>Alias:</strong> MARMOL.ADOBO.DILEMA</p>
          <p style="font-size:0.95rem;color:var(--ink);margin-bottom:16px;"><strong>Titular:</strong> Bernabe Rodriguez</p>
          <br/>
          <p style="font-size:0.95rem;color:var(--ink);margin-bottom:12px;"><strong>Monto $13.775</strong> (5% off)</p>
          <a href="/confirmacion/<%= order.id %>" class="plan-cta" style="text-align:center;text-decoration:none;display:block;">
            Ya transferí
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    function toggleTransferencia() {
      const details = document.getElementById('transferencia-details');
      if (details.style.display === 'none') {
        details.style.display = 'block';
      } else {
        details.style.display = 'none';
      }
    }
  </script>
</body>
</html>

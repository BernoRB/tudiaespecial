<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin pedidos · login</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body style="background:var(--warm-white);">
  <section style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:32px 16px;">
    <div style="max-width:400px;width:100%;background:#fff;border:1px solid var(--border);border-radius:6px;padding:24px;box-shadow:var(--shadow-soft);">
      <h1 style="font-family:'Playfair Display',serif;font-size:1.5rem;margin-bottom:8px;">Admin de pedidos</h1>
      <p style="font-size:0.9rem;color:var(--muted);margin-bottom:14px;">Ingresá tu PIN maestro para gestionar solicitudes y publicar invitaciones.</p>
      <% if (error) { %>
        <div style="margin-bottom:10px;background:#ffeef0;color:#b4232c;border:1px solid #f3b7bd;padding:8px;border-radius:4px;font-size:0.85rem;"><%= error %></div>
      <% } %>
      <form method="post" action="/admin/orders/login">
        <label for="pin" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.14em;color:var(--muted);display:block;margin-bottom:4px;">PIN</label>
        <input id="pin" name="pin" type="password" required style="width:100%;padding:10px;border:1px solid var(--border);border-radius:4px;margin-bottom:12px;" />
        <button class="plan-cta" type="submit" style="width:100%;margin-top:0;">Ingresar</button>
      </form>
    </div>
  </section>
</body>
</html>


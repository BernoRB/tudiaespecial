<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin pedidos</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body style="background:var(--warm-white);">
  <nav>
    <div class="nav-logo">TuDia<span>Especial</span></div>
  </nav>
  <section style="padding-top:110px;padding-bottom:60px;">
    <div style="max-width:1400px;margin:0 auto;padding:0 20px;">
      <h1 class="section-title" style="margin-bottom:8px;">Pedidos recibidos</h1>
      <p class="section-sub" style="margin-bottom:18px;">Desde acá podés publicar una invitación y obtener el link final para enviar al cliente.</p>

      <% if (published) { %>
        <div style="background:#edf9f0;border:1px solid #b8e1c2;border-radius:6px;padding:12px 14px;margin-bottom:16px;font-size:0.9rem;">
          <div><strong>Publicado pedido #<%= published.orderId %></strong></div>
          <div>Slug: <code><%= published.slug %></code></div>
          <div>PIN admin cliente: <code><%= published.adminPin %></code></div>
          <div>Link invitación: <a href="<%= published.inviteUrl %>" target="_blank"><%= published.inviteUrl %></a></div>
          <div>Link panel cliente: <a href="<%= published.adminUrl %>" target="_blank"><%= published.adminUrl %></a></div>
        </div>
      <% } %>

      <div style="background:#fff;border:1px solid var(--border);border-radius:6px;overflow:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:0.85rem;min-width:900px;">
          <thead style="background:var(--offwhite);">
            <tr>
              <th style="padding:10px;border-bottom:1px solid var(--border);text-align:left;">ID</th>
              <th style="padding:10px;border-bottom:1px solid var(--border);text-align:left;">Fecha</th>
              <th style="padding:10px;border-bottom:1px solid var(--border);text-align:left;">Cliente</th>
              <th style="padding:10px;border-bottom:1px solid var(--border);text-align:left;">Categoría</th>
              <th style="padding:10px;border-bottom:1px solid var(--border);text-align:left;">Template</th>
              <th style="padding:10px;border-bottom:1px solid var(--border);text-align:left;">Contacto</th>
              <th style="padding:10px;border-bottom:1px solid var(--border);text-align:left;">Pago</th>
              <th style="padding:10px;border-bottom:1px solid var(--border);text-align:left;">Estado</th>
              <th style="padding:10px;border-bottom:1px solid var(--border);text-align:left;">Notas</th>
              <th style="padding:10px;border-bottom:1px solid var(--border);text-align:left;">PIN</th>
              <th style="padding:10px;border-bottom:1px solid var(--border);text-align:left;">Publicar</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(function(order){ %>
              <%
                try {
                  var formData = JSON.parse(order.raw_form_json || '{}');
                } catch(e) {
                  var formData = {};
                }
              %>
              <tr>
                <td style="padding:9px;border-bottom:1px solid var(--border);">#<%= order._id %></td>
                <td style="padding:9px;border-bottom:1px solid var(--border);"><%= order.created_at %></td>
                <td style="padding:9px;border-bottom:1px solid var(--border);"><%= order.customer_name || "-" %></td>
                <td style="padding:9px;border-bottom:1px solid var(--border);"><%= order.category %></td>
                <td style="padding:9px;border-bottom:1px solid var(--border);"><%= order.template_key || "-" %></td>
                <td style="padding:9px;border-bottom:1px solid var(--border);"><%= order.customer_email %><br/><%= order.customer_whatsapp %></td>
                <td style="padding:9px;border-bottom:1px solid var(--border);"><%= order.payment_method || "-" %></td>
                <td style="padding:9px;border-bottom:1px solid var(--border);"><%= order.status %></td>
                <td style="padding:9px;border-bottom:1px solid var(--border);white-space:normal;min-width:280px;">
                  <ul style="margin:0;padding-left:18px;list-style-type:disc;font-size:0.8rem;line-height:1.4;">
                    <% if (formData.honorees) { %><li><strong>Agasajado:</strong> <%= formData.honorees %></li><% } %>
                    <% if (formData.date) { %><li><strong>Fecha:</strong> <%= formData.date %></li><% } %>
                    <% if (formData.time) { %><li><strong>Hora:</strong> <%= formData.time %></li><% } %>
                    <% if (formData.venue_name) { %><li><strong>Lugar:</strong> <%= formData.venue_name %></li><% } %>
                    <% if (formData.dress_code) { %><li><strong>Dress code:</strong> <%= formData.dress_code %></li><% } %>
                    <% if (order.category === 'bodas') { %>
                      <% if (formData.civil_enabled) { %><li><strong>Civil:</strong> <%= formData.civil_date || '-' %> <%= formData.civil_time || '-' %></li><% } %>
                      <% if (formData.church_enabled) { %><li><strong>Iglesia:</strong> <%= formData.church_date || '-' %> <%= formData.church_time || '-' %></li><% } %>
                      <% if (formData.party_enabled) { %><li><strong>Fiesta:</strong> <%= formData.party_date || '-' %> <%= formData.party_time || '-' %></li><% } %>
                    <% } %>
                    <% if (order.category === 'peques' || order.category === 'ninos') { %>
                      <% if (formData.age_years) { %><li><strong>Edad:</strong> <%= formData.age_years %> años</li><% } %>
                    <% } %>
                    <% if (order.category === 'eventos') { %>
                      <% if (formData.event_type) { %><li><strong>Tipo de evento:</strong> <%= formData.event_type %></li><% } %>
                    <% } %>
                    <% if (formData.notes) { %><li><strong>Notas:</strong> <%= formData.notes %></li><% } %>
                  </ul>
                </td>
                <td style="padding:9px;border-bottom:1px solid var(--border);"><%= order.event_admin_pin || "-" %></td>
                <td style="padding:9px;border-bottom:1px solid var(--border);">
                  <% if (!order.event_id) { %>
                    <a href="/admin/orders/<%= order._id %>/publish" style="background:var(--gold);border:none;border-radius:4px;padding:8px 10px;font-size:0.75rem;cursor:pointer;text-decoration:none;display:inline-block;">Publicar invitación</a>
                  <% } else { %>
                    <div style="display:grid;gap:6px;">
                      <div>Publicado</div>
                      <a href="/admin/events/<%= order.event_id %>/edit" style="font-size:0.75rem;color:var(--ink);">Editar invitación</a>
                    </div>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</body>
</html>


<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Panel de invitados · <%= event.slug %></title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
  <style>
    .admin-wrap{max-width:1220px;margin:0 auto;padding:0 16px;}
    .admin-tools{display:flex;flex-wrap:wrap;gap:10px;align-items:end;margin-bottom:18px;background:#fff;border:1px solid var(--border);border-radius:4px;padding:14px;}
    .admin-tools label{display:block;font-size:.72rem;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin-bottom:5px;}
    .admin-tools select{min-width:180px;border:1px solid var(--border);border-radius:4px;padding:9px 10px;background:white;font:inherit;}
    .admin-btn{border:1px solid var(--ink);background:var(--ink);color:#fff;border-radius:4px;padding:10px 13px;text-decoration:none;font:inherit;font-size:.86rem;cursor:pointer;display:inline-block;}
    .admin-btn.secondary{background:#fff;color:var(--ink);}
    .admin-btn.danger{background:#fff;color:#9b1c1c;border-color:#e0b5b5;padding:7px 9px;font-size:.78rem;}
    .table-scroll{background:white;border-radius:4px;border:1px solid var(--border);overflow-x:auto;-webkit-overflow-scrolling:touch;}
    .admin-table{width:100%;min-width:1120px;border-collapse:collapse;font-size:.86rem;}
    @media (max-width: 760px){.admin-wrap{padding:0 10px}.admin-tools>*{width:100%}.admin-tools select,.admin-btn{width:100%;}.section-title{font-size:2rem;}}
  </style>
</head>
<body style="background:var(--warm-white);">
  <nav>
    <div class="nav-logo">TuDia<span>Especial</span></div>
  </nav>

  <section style="padding-top:110px;padding-bottom:60px;">
    <div class="admin-wrap">
      <div style="margin-bottom:24px;">
        <span class="section-label">Panel del evento</span>
        <h1 class="section-title" style="margin-bottom:8px;">Invitados de <%= event.honorees || event.slug %></h1>
        <p class="section-sub">
          Acá ves quién confirmó, cuántos vienen y los detalles que dejaron.
        </p>
        <% if (groupEvents && groupEvents.length > 1) { %>
          <p style="font-size:0.9rem;color:var(--muted);margin-top:8px;">
            Este panel agrupa <%= groupEvents.length %> invitaciones del mismo evento.
          </p>
        <% } %>
      </div>

      <div style="display:flex;flex-wrap:wrap;gap:16px;margin-bottom:22px;">
        <div style="flex:1;min-width:180px;background:var(--offwhite);padding:14px 16px;border-radius:4px;border:1px solid var(--border);">
          <div style="font-size:0.8rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.14em;margin-bottom:4px;">Confirmados</div>
          <div style="font-family:'Playfair Display',serif;font-size:1.8rem;color:var(--ink);"><%= totals.confirmedCount %></div>
        </div>
        <div style="flex:1;min-width:180px;background:var(--offwhite);padding:14px 16px;border-radius:4px;border:1px solid var(--border);">
          <div style="font-size:0.8rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.14em;margin-bottom:4px;">No asisten</div>
          <div style="font-family:'Playfair Display',serif;font-size:1.8rem;color:var(--ink);"><%= totals.declinedCount %></div>
        </div>
      </div>

      <% if (totalsByEvent && totalsByEvent.length > 1) { %>
      <div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:22px;">
        <% totalsByEvent.forEach(function(item) { %>
          <div style="flex:1;min-width:220px;background:#fff;padding:14px 16px;border-radius:4px;border:1px solid var(--border);">
            <div style="font-size:0.78rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.12em;margin-bottom:6px;"><%= item.label %></div>
            <div style="display:flex;gap:18px;font-size:0.9rem;">
              <div><strong><%= item.confirmedCount %></strong> confirmados</div>
              <div><strong><%= item.declinedCount %></strong> no asisten</div>
            </div>
          </div>
        <% }) %>
      </div>
      <% } %>

      <%
        const isGroupedAdmin = groupEvents && groupEvents.length > 1;
        const adminQuery = isGroupedAdmin
          ? new URLSearchParams({ status: selectedStatus || '', event_id: selectedEventId || '' }).toString()
          : new URLSearchParams({ status: selectedStatus || '' }).toString();
      %>
      <form class="admin-tools" method="get" action="/<%= event.slug %>/admin" id="filters-form">
        <div>
          <label for="status">Estado</label>
          <select id="status" name="status">
            <option value="" <%= !selectedStatus ? 'selected' : '' %>>Todos</option>
            <option value="confirmed" <%= selectedStatus === 'confirmed' ? 'selected' : '' %>>Confirmados</option>
            <option value="declined" <%= selectedStatus === 'declined' ? 'selected' : '' %>>No asisten</option>
          </select>
        </div>
        <% if (isGroupedAdmin) { %>
          <div>
            <label for="event_id">Invitaci&oacute;n</label>
            <select id="event_id" name="event_id">
              <option value="" <%= !selectedEventId ? 'selected' : '' %>>Todas</option>
              <% groupEvents.forEach(function(item) { %>
                <option value="<%= item._id %>" <%= selectedEventId === String(item._id) ? 'selected' : '' %>><%= item.custom_data?.variant_label || item.title || item.slug %></option>
              <% }) %>
            </select>
          </div>
        <% } %>
        <a class="admin-btn secondary" href="/<%= event.slug %>/admin/export.xlsx?<%= adminQuery %>">Exportar XLSX</a>
      </form>

      <div class="table-scroll">
        <table class="admin-table">
          <thead style="background:var(--offwhite);text-align:left;">
            <tr>
              <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Quién confirma</th>
              <% if (isGroupedAdmin) { %>
                <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Invitación</th>
              <% } %>
              <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Personas</th>
              <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Estado</th>
              <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Nombres</th>
              <% if (showFoodPreferences !== false) { %>
                <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Comida</th>
              <% } %>
              <% if (showSongSuggestions) { %>
                <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Temas</th>
              <% } %>
              <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Comentarios</th>
              <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Fecha</th>
              <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (rsvps && rsvps.length) { %>
              <% rsvps.forEach(function(r) { %>
                <tr>
                  <td style="padding:8px 10px;border-bottom:1px solid var(--border);"><%= r.contact_name %></td>
                  <% if (isGroupedAdmin) { %>
                    <td style="padding:8px 10px;border-bottom:1px solid var(--border);"><%= r.event_label || '-' %></td>
                  <% } %>
                  <td style="padding:8px 10px;border-bottom:1px solid var(--border);"><%= r.people_count %></td>
                  <td style="padding:8px 10px;border-bottom:1px solid var(--border);">
                    <% if (r.status === 'confirmed') { %>
                      Confirmado
                    <% } else if (r.status === 'declined') { %>
                      No asiste
                    <% } else { %>
                      <%= r.status %>
                    <% } %>
                  </td>
                  <td style="padding:8px 10px;border-bottom:1px solid var(--border);white-space:pre-wrap;"><%= r.people_names || '-' %></td>
                  <% if (showFoodPreferences !== false) { %>
                    <td style="padding:8px 10px;border-bottom:1px solid var(--border);white-space:pre-wrap;"><%= r.food_preferences || '-' %></td>
                  <% } %>
                  <% if (showSongSuggestions) { %>
                    <td style="padding:8px 10px;border-bottom:1px solid var(--border);white-space:pre-wrap;"><%= r.song_suggestions || '-' %></td>
                  <% } %>
                  <td style="padding:8px 10px;border-bottom:1px solid var(--border);white-space:pre-wrap;"><%= r.comments || '-' %></td>
                  <td style="padding:8px 10px;border-bottom:1px solid var(--border);white-space:nowrap;"><%= r.created_at_display || '-' %></td>
                  <td style="padding:8px 10px;border-bottom:1px solid var(--border);">
                    <form method="post" action="/<%= event.slug %>/admin/rsvps/<%= r._id %>/delete?<%= adminQuery %>" onsubmit="return confirm('Eliminar esta confirmacion?');">
                      <button class="admin-btn danger" type="submit">Eliminar</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="<%= (isGroupedAdmin ? 8 : 7) + (showFoodPreferences !== false ? 1 : 0) + (showSongSuggestions ? 1 : 0) %>" style="padding:14px 10px;text-align:center;color:var(--muted);font-size:0.9rem;">
                  Todavía no hay confirmaciones. Compartí tu invitación para empezar a ver respuestas acá.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
  <script>
    (function(){
      const form = document.getElementById("filters-form");
      if (!form) return;
      form.querySelectorAll("select").forEach(function(select){
        select.addEventListener("change", function(){ form.submit(); });
      });
    })();
  </script>
</body>
</html>

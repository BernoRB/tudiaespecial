<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Panel de invitados · <%= event.slug %></title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body style="background:var(--warm-white);">
  <nav>
    <div class="nav-logo">TuDia<span>Especial</span></div>
  </nav>

  <section style="padding-top:110px;padding-bottom:60px;">
    <div style="max-width:900px;margin:0 auto;">
      <div style="margin-bottom:24px;">
        <span class="section-label">Panel del evento</span>
        <h1 class="section-title" style="margin-bottom:8px;">Invitados de <%= event.honorees || event.slug %></h1>
        <p class="section-sub">
          Acá ves quién confirmó, cuántos vienen y los detalles que dejaron.
        </p>
      </div>

      <div style="display:flex;flex-wrap:wrap;gap:16px;margin-bottom:22px;">
        <div style="flex:1;min-width:180px;background:var(--offwhite);padding:14px 16px;border-radius:4px;border:1px solid var(--border);">
          <div style="font-size:0.8rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.14em;margin-bottom:4px;">Confirmados</div>
          <div style="font-family:'Playfair Display',serif;font-size:1.8rem;color:var(--ink);"><%= totals.confirmedCount %></div>
        </div>
        <div style="flex:1;min-width:180px;background:var(--offwhite);padding:14px 16px;border-radius:4px;border:1px solid var(--border);">
          <div style="font-size:0.8rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.14em;margin-bottom:4px;">No asisten</div>
          <div style="font-family:'Playfair Display',serif;font-size:1.8rem;color:var(--ink);"><%= totals.declinedCount %></div>
        </div>
      </div>

      <div style="background:white;border-radius:4px;border:1px solid var(--border);overflow:hidden;">
        <table style="width:100%;border-collapse:collapse;font-size:0.86rem;">
          <thead style="background:var(--offwhite);text-align:left;">
            <tr>
              <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Quién confirma</th>
              <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Personas</th>
              <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Estado</th>
              <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Nombres</th>
              <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Comida</th>
              <th style="padding:10px 10px;border-bottom:1px solid var(--border);">Comentarios</th>
            </tr>
          </thead>
          <tbody>
            <% if (rsvps && rsvps.length) { %>
              <% rsvps.forEach(function(r) { %>
                <tr>
                  <td style="padding:8px 10px;border-bottom:1px solid var(--border);"><%= r.contact_name %></td>
                  <td style="padding:8px 10px;border-bottom:1px solid var(--border);"><%= r.people_count %></td>
                  <td style="padding:8px 10px;border-bottom:1px solid var(--border);">
                    <% if (r.status === 'confirmed') { %>
                      Confirmado
                    <% } else if (r.status === 'declined') { %>
                      No asiste
                    <% } else { %>
                      <%= r.status %>
                    <% } %>
                  </td>
                  <td style="padding:8px 10px;border-bottom:1px solid var(--border);white-space:pre-wrap;"><%= r.people_names || '-' %></td>
                  <td style="padding:8px 10px;border-bottom:1px solid var(--border);white-space:pre-wrap;"><%= r.food_preferences || '-' %></td>
                  <td style="padding:8px 10px;border-bottom:1px solid var(--border);white-space:pre-wrap;"><%= r.comments || '-' %></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="6" style="padding:14px 10px;text-align:center;color:var(--muted);font-size:0.9rem;">
                  Todavía no hay confirmaciones. Compartí tu invitación para empezar a ver respuestas acá.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</body>
</html>


<script>
  const words = ["evento", "boda", "cumple", "asado", "festejo"];
  let currentIndex = 0;
  const slotWord = document.getElementById("slotWord");

  function rotateWord() {
    slotWord.classList.add("animating");
    
    setTimeout(() => {
      currentIndex = (currentIndex + 1) % words.length;
      slotWord.textContent = words[currentIndex];
    }, 250);

    setTimeout(() => {
      slotWord.classList.remove("animating");
    }, 500);
  }

  setInterval(rotateWord, 2500);
</script>


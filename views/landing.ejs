<!-- HERO -->
<section class="hero" id="hero" style="padding:0;min-height:auto;align-items:flex-start;padding-top:100px;padding-bottom:80px;">
  <div class="hero-bg-pattern"></div>
  <!-- ACÁ PONÉ LA FOTO DEL HERO -->
  <div class="hero-image">
    <img src="/images/hero-photo.jpg" alt="Invitación digital elegante">
  </div>
  <div class="hero-inner">
    <div class="hero-kicker reveal">Bodas · Quinces · Eventos</div>
    <h1 class="reveal reveal-delay-1">
      Tu <span class="slot-word" id="slotWord">evento</span> comienza<br/>con <em>un click,</em><br/>no con un sobre
    </h1>
    <p class="hero-sub reveal reveal-delay-2" style="font-family:'Inter',sans-serif;font-weight:500;">Invitaciones digitales interactivas para tu celebración especial </p>
    <style>
      @media (max-width: 768px) {
        .hero-sub {
          padding: 0 16px !important;
        }
      }
      .slot-word {
        color: var(--gold);
        font-style: italic;
        font-size: 1.1em;
        font-weight: 700;
        display: inline-block;
        position: relative;
        transition: all 0.5s ease;
      }
      .reveal.reveal-delay-1 {
        /* padding: 0 20px; */
      }
      .slot-word.animating {
        animation: slotSpin 0.5s ease-in-out;
      }
      @keyframes slotSpin {
        0% {
          transform: translateY(0);
          opacity: 1;
          filter: blur(0);
        }
        50% {
          transform: translateY(-20px);
          opacity: 0;
          filter: blur(4px);
        }
        51% {
          transform: translateY(20px);
          opacity: 0;
          filter: blur(4px);
        }
        100% {
          transform: translateY(0);
          opacity: 1;
          filter: blur(0);
        }
      }
    </style>
    <div class="hero-buttons reveal reveal-delay-3">
      <a href="#galeria" class="btn-primary" style="border-radius:4px;padding:10px 24px;text-transform:none;font-family:'Inter',sans-serif;font-size:14.4px;font-weight:500;;">Ver diseños</a>

                    <div class="template-preview-placeholder">Imagen no disponible</div>
                  </div>
                </label>
              </div>
              <div class="carousel-item">
                <h4 class="template-preview-title">Quinces Floral</h4>
                <label style="cursor:pointer;display:block;">
                  <input type="radio" name="template_key" value="quinces_floral" style="position:absolute;opacity:0;">
                  <div class="template-preview-card">

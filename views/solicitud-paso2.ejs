      <!-- Secciones a activar -->
      <div style="grid-column:1 / -1;margin-top:8px;">
        <h3 style="font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:8px;">¿Qué secciones querés activar?</h3>
        <!-- <p style="font-size:0.85rem;color:var(--muted);margin-bottom:12px;">Todas están tildadas por defecto. Desmarcá las que no querés.</p> -->
      </div>

      <div style="grid-column:1 / -1;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;">
        <label style="font-size:0.9rem;color:var(--ink-soft);">
          <input type="checkbox" name="section_countdown" checked> Cuenta regresiva
        </label>
        <label style="font-size:0.9rem;color:var(--ink-soft);">
          <input type="checkbox" name="section_gallery" checked> Galería de fotos superior
        </label>
        <label style="font-size:0.9rem;color:var(--ink-soft);">
          <input type="checkbox" name="section_gallery2" checked> Galería de fotos inferior
        </label>
        <label style="font-size:0.9rem;color:var(--ink-soft);">
          <input type="checkbox" name="section_location" checked> Ubicación / mapa
        </label>
        <% if (order.category !== 'quinces' && order.category !== 'peques' && order.category !== 'ninos') { %>
        <label style="font-size:0.9rem;color:var(--ink-soft);">
          <input type="checkbox" name="section_itinerary" checked> Cronograma del evento
        </label>
        <% } %>
        <% if (order.category === 'quinces') { %>
        <label style="font-size:0.9rem;color:var(--ink-soft);opacity:0.6;cursor:not-allowed;" title="Próximamente">
          <input type="checkbox" name="section_trivia" checked disabled> Trivia (Próximamente)
        </label>
        <% } %>
        <% if (order.category !== 'peques' && order.category !== 'ninos') { %>
        <label style="font-size:0.9rem;color:var(--ink-soft);">
          <input type="checkbox" name="section_dress_code" checked> Dress code
        </label>
        <% } %>
        <% if (order.category !== 'peques' && order.category !== 'ninos') { %>
        <label style="font-size:0.9rem;color:var(--ink-soft);">
          <input type="checkbox" name="section_gifts" checked> Sección de regalos / CBU
        </label>
        <% } %>
        <label style="font-size:0.9rem;color:var(--ink-soft);">
          <input type="checkbox" name="section_rsvp" checked> Confirmar asistencia
        </label>
      </div>

      <!-- Datos del evento -->
      <div style="grid-column:1 / -1;margin-top:16px;">
        <h3 style="font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:8px;">Datos del evento</h3>
      </div>

      <% if (order.category === 'bodas') { %>
      <!-- Bodas -->
      <div>
        <label for="honorees" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Nombres de los agasajados *</label>
        <input type="text" id="honorees" name="honorees" required placeholder="Ej: Facundo & Patricia" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
      </div>

      <div>
        <label for="hero_message" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Frase principal (opcional)</label>
        <input type="text" id="hero_message" name="hero_message" placeholder="Ej: Nos casamos" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
      </div>

      <div>
        <label for="dress_code" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Dress code (opcional)</label>
        <input type="text" id="dress_code" name="dress_code" placeholder="Ej: Elegante, informal chic, etc." style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
      </div>
      <div>
        <label for="reserved_color" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Color reservado (opcional)</label>
        <input type="text" id="reserved_color" name="reserved_color" placeholder="Ej: Blanco, para la novia" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
      </div>

      <!-- Civil -->
      <div style="grid-column:1 / -1;">
        <label style="font-size:0.9rem;color:var(--ink-soft);">
          <input type="checkbox" id="civil_enabled" name="civil_enabled" onchange="toggleCeremonyFields('civil')"> ¿Incluir casamiento por civil?
        </label>
      </div>
      <div id="civil_fields" style="display:none;grid-template-columns:1fr 1fr;gap:18px;">
        <div>
          <label for="civil_date" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Fecha del civil</label>
          <input type="text" id="civil_date" name="civil_date" placeholder="dd/mm/aaaa" pattern="(0[1-9]|[12][0-9]|3[01])/(0[1-9]|1[0-2])/\d{4}" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
        </div>
        <div>
          <label for="civil_time" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Hora del civil</label>
          <input type="time" id="civil_time" name="civil_time" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
        </div>
        <div style="grid-column:1 / -1;">
          <label for="civil_address" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Dirección del civil</label>
          <input type="text" id="civil_address" name="civil_address" placeholder="Dirección del registro civil" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
        </div>
      </div>

      <!-- Iglesia -->
      <div style="grid-column:1 / -1;">
        <label style="font-size:0.9rem;color:var(--ink-soft);">
          <input type="checkbox" id="church_enabled" name="church_enabled" onchange="toggleCeremonyFields('church')"> ¿Incluir casamiento por iglesia?
        </label>
      </div>
      <div id="church_fields" style="display:none;grid-template-columns:1fr 1fr;gap:18px;">
        <div>
          <label for="church_date" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Fecha de iglesia</label>
          <input type="text" id="church_date" name="church_date" placeholder="dd/mm/aaaa" pattern="(0[1-9]|[12][0-9]|3[01])/(0[1-9]|1[0-2])/\d{4}" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
        </div>
        <div>
          <label for="church_time" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Hora de iglesia</label>
          <input type="time" id="church_time" name="church_time" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
        </div>
        <div style="grid-column:1 / -1;">
          <label for="church_address" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Dirección de la iglesia</label>
          <input type="text" id="church_address" name="church_address" placeholder="Dirección de la iglesia" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
        </div>
      </div>

      <!-- Fiesta -->
      <div style="grid-column:1 / -1;">
        <label style="font-size:0.9rem;color:var(--ink-soft);">
          <input type="checkbox" id="party_enabled" name="party_enabled" onchange="toggleCeremonyFields('party')"> ¿Incluir fiesta de casamiento?
        </label>
      </div>
      <div id="party_fields" style="display:none;grid-template-columns:1fr 1fr;gap:18px;">
        <div>
          <label for="party_date" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Fecha del evento</label>
          <input type="text" id="party_date" name="party_date" placeholder="dd/mm/aaaa" pattern="(0[1-9]|[12][0-9]|3[01])/(0[1-9]|1[0-2])/\d{4}" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
        </div>
        <div>
          <label for="party_time" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Hora del evento</label>
          <input type="time" id="party_time" name="party_time" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
        </div>
        <div>
          <label for="venue_name" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Lugar del evento</label>
          <input type="text" id="venue_name" name="venue_name" placeholder="Nombre del salón" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
        </div>
        <div style="grid-column:1 / -1;">
          <label for="party_address" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Dirección del evento</label>
          <input type="text" id="party_address" name="party_address" placeholder="Dirección completa" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
        </div>
      </div>

      <% } else { %>
      <!-- Quinces, Peques, Niños, Eventos -->
      <div>
        <label for="honorees" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">
          <% if (order.category === 'quinces') { %>
            Nombre de la cumpleañera
          <% } else if (order.category === 'peques' || order.category === 'ninos') { %>
            Nombre del cumpleañero
          <% } else { %>
            Nombre del/de los agasajado/s
          <% } %> *
        </label>
        <input type="text" id="honorees" name="honorees" required placeholder="Ej: María" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
      </div>

      <% if (order.category === 'peques' || order.category === 'ninos') { %>
      <div>
        <label for="age_years" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Edad del cumpleañero *</label>
        <input type="number" id="age_years" name="age_years" required min="0" max="18" placeholder="Ej: 3" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
      </div>
      <% } %>

      <% if (order.category === 'eventos') { %>
      <div>
        <label for="event_type" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">¿Qué es el evento? *</label>
        <input type="text" id="event_type" name="event_type" required placeholder="Ej: Mis 40, Mis 30, Mis Bodas de Plata" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
      </div>
      <% } %>

      <div>
        <label for="hero_message" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Frase principal (opcional)</label>
        <input type="text" id="hero_message" name="hero_message" placeholder="Ej: La fiesta que soñé" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
      </div>

      <% if (order.category !== 'peques' && order.category !== 'ninos') { %>
      <div>
        <label for="dress_code" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Dress code (opcional)</label>
        <input type="text" id="dress_code" name="dress_code" placeholder="Ej: Chic de fiesta" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
      </div>
      <% } %>

      <% if (order.category === 'quinces') { %>
      <div>
        <label for="reserved_color" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">¿Hay algún color de vestimenta reservado?</label>
        <input type="text" id="reserved_color" name="reserved_color" placeholder="Ej: Blanco, rosa, etc." style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
      </div>
      <% } %>

      <div>
        <label for="date" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Fecha *</label>
        <input type="date" id="date" name="date" required style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
      </div>

      <div>
        <label for="time" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Hora *</label>
        <input type="time" id="time" name="time" required style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
      </div>

      <div>
        <label for="venue_name" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Lugar</label>
        <input type="text" id="venue_name" name="venue_name" placeholder="Nombre del salón / lugar" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
      </div>

      <div style="grid-column:1 / -1;">
        <label for="venue_address" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Dirección *</label>
        <input type="text" id="venue_address" name="venue_address" required placeholder="Dirección completa" style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;">
      </div>
      <% } %>

      <!-- Notas -->
      <div style="grid-column:1 / -1;margin-top:8px;">
        <label for="notes" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);display:block;margin-bottom:6px;">Notas / Comentarios</label>
        <textarea id="notes" name="notes" rows="4" placeholder="Ej: detalles especiales, CBU/Alias para regalos, aclaraciones del evento, etc." style="width:100%;padding:10px 12px;border-radius:2px;border:1px solid var(--border);font-size:0.9rem;font-family:'Jost',sans-serif;"></textarea>
      </div>

      <!-- Botón enviar -->
      <div style="grid-column:1 / -1;margin-top:12px;">
        <button type="submit" class="plan-cta" style="margin-top:8px;">
          Continuar →
        </button>
      </div>
    </form>
  </section>

  <script>
    function toggleCeremonyFields(type) {
      const checkbox = document.getElementById(type + '_enabled');
      const fields = document.getElementById(type + '_fields');
      if (checkbox && fields) {
        fields.style.display = checkbox.checked ? 'grid' : 'none';
      }
    }
    
    function updateSelectedTemplateText(category) {
      const selectedRadio = document.querySelector(`input[name="template_key"]:checked`);
      if (selectedRadio) {
        const templateValue = selectedRadio.value;
        const templateName = getTemplateName(templateValue);
        const demoUrl = getDemoUrl(category, templateValue);
        const textElement = document.getElementById(`${category}-selected-text`);
        if (textElement) {
          textElement.innerHTML = `Plantilla seleccionada: <strong>${templateName}</strong><br><a id="${category}-preview-link" href="${demoUrl}" target="_blank">(Toca para ver completa)</a>`;
        }
      }
    }
    
    function getTemplateName(value) {
      const names = {
        'boda_minimal': 'Boda Minimal',
        'boda_midnight': 'Boda Midnight',
        'boda_garden': 'Boda Garden',
        'boda_ethereal': 'Boda Ethereal',
        'boda_eclipse': 'Boda Eclipse',
        'quinces_glow': 'Quinces Glow',
        'quinces_royal': 'Quinces Royal',
        'quinces_velvet': 'Quinces Velvet',
        'quinces_floral': 'Quinces Floral',
        'quinces_diamond': 'Quinces Diamond',
        'peques_soft': 'Peques Soft',
        'peques_cloud': 'Peques Cloud',
        'peques_dream': 'Peques Dream',
        'ninos_batman': 'Niños Batman',
        'ninos_ironman': 'Niños IronMan',
        'ninos_spiderman': 'Niños SpiderMan',
        'eventos_dark': 'Cumpleaños Oscuro',
        'eventos_light': 'Cumpleaños Claro',
        'eventos_anniversary': 'Aniversario',
        'eventos_bachelor': 'Despedida Hombre',
        'eventos_bachelorette': 'Despedida Mujer',
        'eventos_bbq': 'Asado Oficial'
      };
      return names[value] || value;
    }
    
    function getDemoUrl(category, templateValue) {
      const categoryMap = {
        'bodas': 'bodas',
        'quinces': 'quinces',
        'peques': 'peques',
        'ninos': 'ninos',
        'eventos': 'eventos'
      };
      const cat = categoryMap[category] || category;
      return `/demo/${cat}/${templateValue}`;
    }
    
    // Inicializar estado de campos al cargar la página
    document.addEventListener('DOMContentLoaded', function() {
      toggleCeremonyFields('civil');
      toggleCeremonyFields('church');
      toggleCeremonyFields('party');
      
      // Agregar event listeners a los radio buttons
      const templateRadios = document.querySelectorAll('input[name="template_key"]');
      templateRadios.forEach(radio => {
        radio.addEventListener('change', function() {
          const category = '<%= order.category %>';
          updateSelectedTemplateText(category);
        });
      });
      
      // Actualizar el texto inicial
      updateSelectedTemplateText('<%= order.category %>');
    });
  </script>

  <script src="/js/scripts.js"></script>
</body>
</html>

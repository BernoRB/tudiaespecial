                    <div class="template-preview-placeholder">Imagen no disponible</div>
                  </div>
                </label>
              </div>
            </div>
          </div>
        </div>
        <div class="selected-template-text" id="quinces-selected-text">
          Plantilla seleccionada: <strong>Quinces Glow</strong><br><a id="quinces-preview-link" href="/demo/quinces/quinces_glow" target="_blank">(Toca para ver completa)</a>
        </div>
        <% } else if (order.category === 'peques') { %>
        <div class="carousel-section">
          <div class="carousel-container">
            <button type="button" class="carousel-nav carousel-prev" onclick="moveCarousel('peques', -1)">‹</button>
            <button type="button" class="carousel-nav carousel-next" onclick="moveCarousel('peques', 1)">›</button>
            <div class="carousel-track" id="peques-track">

                </label>
              </div>
              <div class="carousel-item">
                <h4 class="template-preview-title">Quinces Royal</h4>
                <label style="cursor:pointer;display:block;">
                  <input type="radio" name="template_key" value="quinces_royal" style="position:absolute;opacity:0;">
                  <div class="template-preview-card">
                    <img src="/images/templates/mocksTemplates/QuincesRoyal.jpg" alt="Quinces Royal Template" class="template-preview-image" onerror="this.style.display='none';this.nextElementSibling.style.display='block';">

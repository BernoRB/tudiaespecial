                </label>
              </div>
              <div class="carousel-item">
                <h4 class="template-preview-title">Peques Dream</h4>
                <label style="cursor:pointer;display:block;">
                  <input type="radio" name="template_key" value="peques_dream" style="position:absolute;opacity:0;">
                  <div class="template-preview-card">
                    <img src="/images/templates/mocksTemplates/PequesDream.png" alt="Peques Dream Template" class="template-preview-image" onerror="this.style.display='none';this.nextElementSibling.style.display='block';">
                    <div class="template-preview-placeholder">Imagen no disponible</div>
                  </div>
                </label>

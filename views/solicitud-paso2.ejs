                    <div class="template-preview-placeholder">Imagen no disponible</div>
                  </div>
                </label>
              </div>
              <div class="carousel-item">
                <h4 class="template-preview-title">Niños IronMan</h4>
                <label style="cursor:pointer;display:block;">
                  <input type="radio" name="template_key" value="ninos_ironman" style="position:absolute;opacity:0;">
                  <div class="template-preview-card">
                    <img src="/images/templates/mocksTemplates/NinosIronman.png" alt="Niños IronMan Template" class="template-preview-image" onerror="this.style.display='none';this.nextElementSibling.style.display='block';">
                    <div class="template-preview-placeholder">Imagen no disponible</div>
                  </div>
                </label>
              </div>
              <div class="carousel-item">
                <h4 class="template-preview-title">Niños SpiderMan</h4>
                <label style="cursor:pointer;display:block;">
                  <input type="radio" name="template_key" value="ninos_spiderman" style="position:absolute;opacity:0;">
                  <div class="template-preview-card">
                    <img src="/images/templates/mocksTemplates/NinosSpiderman.png" alt="Niños SpiderMan Template" class="template-preview-image" onerror="this.style.display='none';this.nextElementSibling.style.display='block';">

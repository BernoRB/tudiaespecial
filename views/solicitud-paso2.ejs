                    <div class="template-preview-placeholder">Imagen no disponible</div>
                  </div>
                </label>
              </div>
            </div>
          </div>
        </div>
        <div class="selected-template-text" id="bodas-selected-text">
          Plantilla seleccionada: <strong>Boda Minimal</strong><br><a id="bodas-preview-link" href="/demo/bodas/boda_minimal" target="_blank">(Toca para ver completa)</a>
        </div>
        <% } else if (order.category === 'quinces') { %>

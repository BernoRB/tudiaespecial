        </div>
        <% } else if (order.category === 'eventos') { %>
        <div class="carousel-section">
          <div class="carousel-container">
            <button type="button" class="carousel-nav carousel-prev" onclick="moveCarousel('eventos', -1)">‹</button>
            <button type="button" class="carousel-nav carousel-next" onclick="moveCarousel('eventos', 1)">›</button>
            <div class="carousel-track" id="eventos-track">
              <div class="carousel-item">
                <h4 class="template-preview-title">Cumpleaños Oscuro</h4>
                <label style="cursor:pointer;display:block;">
                  <input type="radio" name="template_key" value="eventos_dark" required style="position:absolute;opacity:0;">

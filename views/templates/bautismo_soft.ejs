<!DOCTYPE html>
<html lang="es-AR">
<head>
<%- include('../partials/meta-tags', {
  title: (event.honorees || "Bautismo") + " · Invitación Digital",
  description: (event.honorees || "Bautismo") + " - Invitación digital con confirmación de asistencia, ubicación y galería. Servicio en Argentina.",
  keywords: "invitación digital bautismo, bautismo, " + (event.honorees || "") + ", Argentina",
  url: "https://tudiaespecial.com" + req.originalUrl,
  type: "article"
}) %>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Nunito:wght@300;400;600;700&display=swap" rel="stylesheet" />
<link rel="icon" type="image/png" href="/images/favicon.png">
<style>
  :root{--bg:#f8fbff;--card:#fff;--ink:#32445c;--muted:#718093;--accent:#a9c9e8;--gold:#d8bd7d;--line:rgba(169,201,232,.45);--shadow:0 20px 55px rgba(76,116,156,.16)}
  *{box-sizing:border-box} body{margin:0;font-family:"Nunito",sans-serif;background:linear-gradient(180deg,#eef7ff 0%,#fff 42%,#f9fbff 100%);color:var(--ink)}
  .page{max-width:1080px;margin:0 auto;padding:18px 16px 56px;text-align:center}.hero{position:relative;min-height:88vh;border-radius:24px;overflow:hidden;background:#dcecf8;box-shadow:var(--shadow)}
  .hero img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}.hero:after{content:"";position:absolute;inset:0;background:linear-gradient(to top,rgba(20,36,56,.72),rgba(20,36,56,.2),rgba(20,36,56,.5))}
  .hero-content{position:relative;z-index:1;min-height:88vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:34px 22px;color:#fff}.kicker{letter-spacing:.22em;text-transform:uppercase;font-size:.78rem;color:#dceeff;font-weight:700}
  h1{font-family:"Cormorant Garamond",serif;font-size:clamp(3.6rem,13vw,6.5rem);line-height:.95;margin:18px 0 6px;font-weight:600}.hero-message{font-family:"Cormorant Garamond",serif;font-size:clamp(1.35rem,5vw,2.2rem);font-style:italic;margin:0;color:#fff9ea}
  .countdown{position:absolute;z-index:2;left:50%;bottom:34px;transform:translateX(-50%);display:grid;grid-template-columns:repeat(4,70px);gap:8px}.count-box{background:rgba(255,255,255,.86);border:1px solid rgba(255,255,255,.75);border-radius:16px;padding:10px 4px;color:var(--ink);backdrop-filter:blur(6px)}.count-box strong{display:block;font-size:1.6rem}.count-box span{font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
  .grid{display:grid;gap:26px;margin-top:26px}.card{background:var(--card);border:1px solid var(--line);border-radius:22px;box-shadow:var(--shadow);padding:38px 24px}.section-title{font-family:"Cormorant Garamond",serif;font-size:2.15rem;margin:0 0 8px;color:var(--ink)}.divider{width:82px;height:2px;background:linear-gradient(90deg,var(--accent),var(--gold));margin:0 auto 22px}.sub{color:var(--muted);font-size:1.08rem;line-height:1.65;margin:0}.event-pair{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}.mini{border:1px solid var(--line);border-radius:18px;padding:18px;background:#fbfdff}.mini h3{margin:0 0 8px;font-family:"Cormorant Garamond",serif;font-size:1.5rem;color:var(--ink)}.mini p{margin:6px 0;color:var(--muted);line-height:1.5}.calendar-btn,.map-btn,.send-btn{display:inline-block;margin-top:18px;border:0;border-radius:999px;background:linear-gradient(90deg,var(--accent),#d8eafa);color:#22344b;text-decoration:none;text-transform:uppercase;letter-spacing:.13em;font-weight:700;font-size:.78rem;padding:12px 20px;cursor:pointer}
  .map-wrap{overflow:hidden;border-radius:20px;border:1px solid var(--line);background:#edf6ff}.map-wrap iframe{width:100%;height:330px;border:0;display:block}.gallery{display:flex;gap:12px;overflow-x:auto;scroll-snap-type:x mandatory;padding:4px}.photo{flex:0 0 72%;aspect-ratio:4/5;border-radius:20px;overflow:hidden;scroll-snap-align:start;border:5px solid #fff;box-shadow:0 15px 36px rgba(76,116,156,.18);cursor:pointer}.photo img{width:100%;height:100%;object-fit:cover;display:block}.quote{font-family:"Cormorant Garamond",serif;font-size:1.45rem;line-height:1.7;font-style:italic;color:#40566f}
  .rsvp-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;text-align:left}.field.full{grid-column:1/-1}.field label{display:block;margin-bottom:6px;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:700}.field input,.field select,.field textarea{width:100%;border:1px solid var(--line);border-radius:12px;padding:12px 14px;font:inherit;color:var(--ink);background:#fff}.field textarea{min-height:76px;resize:vertical}.send-btn{width:100%;margin-top:16px}.lightbox{display:none;position:fixed;inset:0;background:rgba(31,48,70,.92);z-index:50;align-items:center;justify-content:center;padding:18px}.lightbox.visible{display:flex}.lightbox img{max-width:100%;max-height:86vh;border-radius:20px}.close{position:absolute;top:14px;right:14px;width:40px;height:40px;border:0;border-radius:50%;background:rgba(255,255,255,.2);color:#fff;font-size:1.5rem;cursor:pointer}
  @media(min-width:900px){.page{max-width:100%;padding:30px 20px 80px}.hero,.card{width:76%;margin-left:auto;margin-right:auto}.photo{flex-basis:28%}.card{padding:50px 44px}.rsvp-grid{text-align:center}}@media(max-width:720px){.event-pair,.rsvp-grid{grid-template-columns:1fr}.countdown{grid-template-columns:repeat(4,58px)}.count-box strong{font-size:1.35rem}.hero{border-radius:0;margin:0 -16px}.page{padding-top:0}}
</style>
</head>
<body>
<%
  const sectionsData = typeof sections !== "undefined" ? sections : (event.sections || {});
  const ceremonies = event.ceremonies || {};
  const church = ceremonies.church || {};
  const party = ceremonies.party || {};
  const hasChurch = church.enabled || church.name || church.time || church.address;
  const hasParty = party.enabled || party.name || party.time || party.address;
  const fallbackBlock = !hasChurch && !hasParty ? { name: event.venue_name || "Lugar del encuentro", time: event.time || "", address: event.venue_address || "", date: event.date || "" } : null;
  const blocks = [];
  if (hasChurch) blocks.push({ label: "Iglesia", name: church.name || "Iglesia", time: church.time || "", address: church.address || "", date: church.date || event.date || "" });
  if (hasParty) blocks.push({ label: "Recepción", name: party.name || event.venue_name || "Recepción", time: party.time || "", address: party.address || event.venue_address || "", date: party.date || event.date || "" });
  if (fallbackBlock) blocks.push({ label: "Encuentro", ...fallbackBlock });
  const mapAddress = (hasParty && party.address) || (hasChurch && church.address) || event.venue_address || event.venue_name || "Buenos Aires";
  const heroImage = event.hero_image || "https://images.unsplash.com/photo-1515488042361-ee00e0ddd4e4?q=80&w=1200&auto=format&fit=crop";
  const galleryImages = event.gallery && event.gallery.length ? event.gallery : [
    "https://images.unsplash.com/photo-1519689680058-324335c77eba?q=80&w=900&auto=format&fit=crop",
    "https://images.unsplash.com/photo-1544126562-807ade215a0b?q=80&w=900&auto=format&fit=crop",
    "https://images.unsplash.com/photo-1519452575417-567c566f1318?q=80&w=900&auto=format&fit=crop"
  ];
  const mainTime = event.time || party.time || church.time || "11:00";
  function formatDate(dateStr){ if(!dateStr) return "Domingo 3 de agosto de 2026"; const d = new Date(dateStr + "T00:00:00"); const m = ["enero","febrero","marzo","abril","mayo","junio","julio","agosto","septiembre","octubre","noviembre","diciembre"]; return `${d.getDate()} de ${m[d.getMonth()]} de ${d.getFullYear()}`; }
  function toGoogleDate(d){ return `${d.getUTCFullYear()}${String(d.getUTCMonth()+1).padStart(2,"0")}${String(d.getUTCDate()).padStart(2,"0")}T${String(d.getUTCHours()).padStart(2,"0")}${String(d.getUTCMinutes()).padStart(2,"0")}00Z`; }
  const start = new Date(`${event.date || "2026-08-03"}T${mainTime}:00`);
  const end = new Date(start.getTime() + 3 * 60 * 60 * 1000);
  const calendarUrl = "https://calendar.google.com/calendar/render?action=TEMPLATE" + `&text=${encodeURIComponent("Bautismo de " + (event.honorees || ""))}` + `&dates=${toGoogleDate(start)}/${toGoogleDate(end)}` + `&details=${encodeURIComponent("Te esperamos para compartir este día tan especial.")}` + `&location=${encodeURIComponent(mapAddress)}`;
%>
<main class="page">
  <header class="hero">
    <img src="<%= heroImage %>" alt="Foto principal del bautismo">
    <div class="hero-content">
      <div class="kicker">Invitación de Bautismo</div>
      <h1><%= event.honorees || "Santino" %></h1>
      <p class="hero-message"><%= event.hero_message || "Con amor y fe" %></p>
    </div>
    <div class="countdown" id="countdown" data-date="<%= event.date || '' %>" data-time="<%= mainTime %>">
      <div class="count-box"><strong data-unit="days">--</strong><span>Días</span></div>
      <div class="count-box"><strong data-unit="hours">--</strong><span>Horas</span></div>
      <div class="count-box"><strong data-unit="minutes">--</strong><span>Min</span></div>
      <div class="count-box"><strong data-unit="seconds">--</strong><span>Seg</span></div>
    </div>
  </header>
  <section class="grid">
    <article class="card"><h2 class="section-title">¿Cuándo?</h2><div class="divider"></div><div class="event-pair"><% blocks.forEach(function(item){ %><div class="mini"><h3><%= item.label %></h3><p><%= formatDate(item.date || event.date) %></p><% if (item.time) { %><p><strong><%= item.time %> hs</strong></p><% } %></div><% }) %></div><a class="calendar-btn" href="<%= calendarUrl %>" target="_blank" rel="noopener noreferrer">Agregar al calendario</a></article>
    <article class="card"><h2 class="section-title">¿Dónde?</h2><div class="divider"></div><div class="event-pair"><% blocks.forEach(function(item){ %><div class="mini"><h3><%= item.label %></h3><p><strong><%= item.name %></strong></p><% if (item.address) { %><p><%= item.address %></p><% } %></div><% }) %></div></article>
    <% if (sectionsData.location) { %><article class="card"><h2 class="section-title">Cómo llegar</h2><div class="divider"></div><div class="map-wrap"><iframe title="Mapa del bautismo" src="https://www.google.com/maps?q=<%= encodeURIComponent(mapAddress) %>&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe></div><a class="map-btn" href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(mapAddress) %>" target="_blank" rel="noopener noreferrer">Abrir mapa</a></article><% } %>
    <% if (sectionsData.gallery) { %><article class="card"><h2 class="section-title">Galería</h2><div class="divider"></div><div class="gallery"><% galleryImages.forEach(function(photo){ %><div class="photo" data-photo="<%= photo %>"><img src="<%= photo %>" alt="Foto de galería"></div><% }) %></div></article><% } %>
    <article class="card"><p class="quote"><%= event.quote_message || "Que este día sea el comienzo de un camino lleno de luz, amor y bendiciones." %></p></article>
  </section>
  <section class="card" style="margin-top:26px"><h2 class="section-title">Confirmar asistencia</h2><div class="divider"></div><p class="sub">Nos encantará saber si vas a acompañarnos.</p><form action="/api/<%= event.slug %>/rsvp" method="post"><div class="rsvp-grid"><div class="field full"><label for="contact_name">Nombre de quien confirma</label><input id="contact_name" name="contact_name" required></div><div class="field"><label for="people_count">¿Cuántos vienen?</label><input type="number" id="people_count" name="people_count" min="1" value="1" required></div><div class="field"><label for="status">Asistencia</label><select id="status" name="status"><option value="confirmed">Voy / Vamos</option><option value="declined">No puedo ir</option></select></div><div class="field full"><label for="people_names">Nombre y apellido de acompañantes</label><textarea id="people_names" name="people_names"></textarea></div><div class="field full"><label for="comments">Mensaje</label><textarea id="comments" name="comments"></textarea></div></div><button class="send-btn" type="submit">Enviar confirmación</button></form></section>
</main>
<div class="lightbox" id="lightbox"><button class="close" id="close" aria-label="Cerrar">×</button><img id="lightbox-image" alt="Foto ampliada"></div>
<script>
(function(){const qs=new URLSearchParams(location.search);if(qs.get("rsvp")==="ok"){alert("Gracias por confirmar tu asistencia.");qs.delete("rsvp");history.replaceState({},"",location.pathname+(qs.toString()?"?"+qs.toString():""));}const el=document.getElementById("countdown");if(el&&el.dataset.date){const target=new Date(el.dataset.date+"T"+(el.dataset.time||"00:00")+":00");function tick(){let diff=Math.max(0,target.getTime()-Date.now());const set=(u,v)=>{const n=el.querySelector('[data-unit="'+u+'"]');if(n)n.textContent=String(v).padStart(2,"0")};set("days",Math.floor(diff/86400000));set("hours",Math.floor(diff/3600000)%24);set("minutes",Math.floor(diff/60000)%60);set("seconds",Math.floor(diff/1000)%60)}tick();setInterval(tick,1000)}const lightbox=document.getElementById("lightbox");const image=document.getElementById("lightbox-image");document.querySelectorAll(".photo").forEach(p=>p.addEventListener("click",()=>{image.src=p.dataset.photo;lightbox.classList.add("visible")}));document.getElementById("close").addEventListener("click",()=>lightbox.classList.remove("visible"));lightbox.addEventListener("click",e=>{if(e.target===lightbox)lightbox.classList.remove("visible")});})();
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="es-AR">
<head>
<%- include('../partials/meta-tags', {
  title: "Mis quince - Picu",
  description: "Picu - Te invito a celebrar mis quince años",
  keywords: "invitacion digital quinces, PICU, Villa del Rosario, Cordoba, Argentina",
  url: "https://tudiaespecial.com" + req.originalUrl,
  image: "https://tudiaespecial.com/images/events/picu-xv/logo-gold.webp?v=20260710xv",
  type: "article"
}) %>

<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
<link rel="icon" type="image/png" href="/images/favicon.png">
<style>
  :root {
    --bg: #050505;
    --card: #101010;
    --card-soft: #15120b;
    --ink: #fffaf0;
    --muted: #ded5c2;
    --muted-strong: #f1e7d1;
    --gold: #d8b45e;
    --gold-bright: #ffe3a0;
    --gold-soft: rgba(216, 180, 94, .16);
    --line: rgba(255, 220, 145, .34);
    --shadow: 0 20px 60px rgba(255, 204, 105, .16);
    --glow: 0 0 8px rgba(255, 230, 170, .86), 0 0 24px rgba(216, 180, 94, .58), 0 0 52px rgba(216, 180, 94, .28);
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: "Lato", sans-serif;
    color: var(--ink);
    background:
      radial-gradient(circle at 12% 0%, rgba(216, 180, 94, .18), transparent 36%),
      radial-gradient(circle at 100% 22%, rgba(255, 255, 255, .09), transparent 38%),
      linear-gradient(135deg, #030303 0%, #0b0905 46%, #050505 100%);
  }
  body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
    background-size: 58px 58px;
    mask-image: linear-gradient(to bottom, rgba(0,0,0,.7), transparent 78%);
  }
  .page {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 18px 16px 64px;
    text-align: center;
  }
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 82vh;
    border-radius: 16px;
    border: 1px solid rgba(20, 16, 8, .82);
    box-shadow: 0 24px 72px rgba(0, 0, 0, .34), 0 0 46px rgba(216, 180, 94, .18);
    margin-bottom: 24px;
    background:
      radial-gradient(circle at 42% 26%, rgba(255, 245, 188, .72), transparent 28%),
      radial-gradient(circle at 68% 64%, rgba(255, 232, 150, .3), transparent 32%),
      linear-gradient(135deg, #a87920 0%, #f4d77d 42%, #be8f2d 100%);
  }
  .hero::before,
  .hero::after {
    content: "";
    position: absolute;
    inset: 18px;
    border: 1px solid rgba(8, 8, 8, .5);
    border-radius: 13px;
    pointer-events: none;
  }
  .hero::after {
    inset: 30px;
    border-color: rgba(255, 246, 205, .34);
  }
  .hero-content {
    position: relative;
    z-index: 3;
    min-height: 82vh;
    padding: 28px 18px 36px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 0;
  }
  .hero-bg {
    position: absolute;
    z-index: 1;
    left: 50%;
    top: 45%;
    width: min(82vw, 570px);
    max-width: none;
    transform: translate(-50%, -50%);
    object-fit: contain;
    opacity: .96;
    filter: drop-shadow(0 14px 18px rgba(45, 32, 8, .18));
    pointer-events: none;
  }
  .hero-date {
    font-family: "Cinzel", serif;
    font-weight: 600;
    color: #070707;
    letter-spacing: .14em;
    text-transform: uppercase;
    font-size: clamp(1.18rem, 5vw, 1.7rem);
    margin-bottom: 3vh;
  }
  .hero-kicker {
    font-family: "Cinzel", serif;
    font-weight: 600;
    color: #080808;
    letter-spacing: .18em;
    text-transform: uppercase;
    font-size: clamp(.82rem, 3.5vw, 1.1rem);
    margin-bottom: 10px;
  }
  .hero-kicker,
  .hero-date {
    text-shadow:
      0 1px 0 rgba(255, 244, 198, .42),
      0 0 10px rgba(255, 226, 140, .46),
      0 0 20px rgba(190, 130, 26, .22);
  }
  .grid {
    display: grid;
    gap: 24px;
  }
  .section-card,
  .rsvp-section {
    background:
      linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.015)),
      var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .section-inner {
    padding: 40px 24px;
  }
  .section-icon {
    width: 72px;
    height: 72px;
    margin: 0 auto 20px;
    object-fit: contain;
    display: block;
    background: #050505;
    border: 2px solid var(--gold);
    border-radius: 50%;
    padding: 8px;
    box-shadow: 0 0 24px rgba(216, 180, 94, .22);
  }
  .section-logo-wrap {
    position: relative;
    width: 142px;
    height: 142px;
    margin: 0 auto 18px;
    display: grid;
    place-items: center;
  }
  .section-logo,
  .section-logo-halo {
    width: 142px;
    height: 142px;
    object-fit: contain;
    display: block;
  }
  .section-logo-halo {
    position: absolute;
    inset: 0;
    opacity: .74;
    filter:
      blur(8px)
      brightness(1.55)
      saturate(1.65)
      drop-shadow(0 0 18px rgba(255, 226, 160, .85))
      drop-shadow(0 0 42px rgba(216, 180, 94, .48));
  }
  .section-logo {
    position: relative;
    z-index: 1;
    filter:
      brightness(1.12)
      saturate(1.22)
      drop-shadow(0 0 8px rgba(255, 226, 160, .64))
      drop-shadow(0 0 20px rgba(216, 180, 94, .42));
  }
  .section-title {
    font-family: "Cinzel", serif;
    font-weight: 600;
    color: var(--gold-bright);
    text-shadow: var(--glow);
    font-size: clamp(1.35rem, 6vw, 2rem);
    letter-spacing: .08em;
    text-transform: uppercase;
    margin: 0 0 14px;
  }
  .section-sub {
    margin: 0 0 16px;
    color: var(--muted);
    font-size: 1.04rem;
    line-height: 1.65;
  }
  .section-divider {
    width: 86px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-bright), transparent);
    margin: 0 auto 22px;
  }
  .countdown {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-top: 12px;
  }
  .count-box {
    border: 1px solid var(--line);
    background: var(--gold-soft);
    border-radius: 8px;
    padding: 13px 6px;
  }
  .count-number {
    display: block;
    font-family: "Cinzel", serif;
    font-weight: 700;
    color: var(--gold-bright);
    text-shadow: var(--glow);
    font-size: clamp(1.28rem, 7vw, 2.05rem);
    line-height: 1;
  }
  .count-label {
    display: block;
    margin-top: 6px;
    color: var(--muted);
    font-size: .64rem;
    letter-spacing: .11em;
    text-transform: uppercase;
  }
  .info-list {
    display: grid;
    gap: 13px;
    color: var(--muted-strong);
    font-size: 1.08rem;
    line-height: 1.65;
  }
  .info-list strong { color: var(--ink); }
  .calendar-btn,
  .map-btn,
  .gift-toggle,
  .send-btn {
    border: 1px solid rgba(255, 226, 160, .55);
    background: linear-gradient(90deg, #9f7829, #f4d58a, #a57d2c);
    color: #080808;
    border-radius: 7px;
    padding: 12px 18px;
    font-family: "Cinzel", serif;
    font-weight: 700;
    font-size: .78rem;
    letter-spacing: .15em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    display: inline-block;
    box-shadow: 0 0 22px rgba(216, 180, 94, .2);
  }
  .calendar-btn { margin-top: 18px; }
  .map-btn { margin-top: 18px; }
  .map-wrap {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: #090909;
  }
  .map-wrap iframe {
    width: 100%;
    height: 270px;
    border: 0;
    display: block;
    filter: grayscale(.18) contrast(1.08);
  }
  .price-groups {
    display: grid;
    gap: 16px;
    max-width: 660px;
    margin: 0 auto;
  }
  .price-group {
    border: 1px solid var(--line);
    background: rgba(255,255,255,.045);
    border-radius: 10px;
    padding: 16px;
  }
  .price-heading {
    font-family: "Cinzel", serif;
    color: var(--gold-bright);
    text-shadow: var(--glow);
    letter-spacing: .12em;
    text-transform: uppercase;
    margin: 0 0 12px;
  }
  .price-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    color: var(--muted-strong);
    border-top: 1px solid rgba(255, 220, 145, .16);
    padding: 11px 0 0;
    margin-top: 11px;
    text-align: left;
  }
  .price-row span:last-child {
    color: var(--gold-bright);
    font-family: "Cinzel", serif;
    white-space: nowrap;
  }
  .gift-toggle {
    width: 100%;
    max-width: 440px;
    margin-top: 12px;
  }
  .gift-box,
  .transfer-box {
    display: none;
    max-width: 560px;
    margin: 14px auto 0;
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 16px;
    background: rgba(0,0,0,.34);
    color: var(--muted-strong);
    line-height: 1.7;
  }
  .gift-box.visible,
  .transfer-box.visible { display: block; }
  .gallery-track {
    display: flex;
    overflow-x: auto;
    gap: 10px;
    padding: 2px 2px 8px;
    scroll-snap-type: x mandatory;
  }
  .gallery-item {
    flex: 0 0 72%;
    aspect-ratio: 4/5;
    border-radius: 9px;
    overflow: hidden;
    border: 2px solid var(--gold);
    background: #090909;
    cursor: pointer;
    scroll-snap-align: start;
    box-shadow: 0 14px 36px rgba(216, 180, 94, .17);
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .quote-text {
    font-family: "Cinzel", serif;
    font-style: italic;
    font-size: clamp(1.08rem, 4.6vw, 1.5rem);
    line-height: 1.8;
    color: var(--ink);
    margin: 0;
  }
  .rsvp-section {
    margin-top: 16px;
    padding: 30px 22px 34px;
  }
  .rsvp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .rsvp-field label {
    display: block;
    margin-bottom: 5px;
    color: var(--muted);
    font-size: .7rem;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .rsvp-field input,
  .rsvp-field select,
  .rsvp-field textarea {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 7px;
    padding: 11px 12px;
    font: inherit;
    font-size: .94rem;
    color: var(--ink);
    background: #080808;
  }
  .rsvp-field textarea {
    min-height: 78px;
    resize: vertical;
  }
  .guest-list {
    display: grid;
    gap: 12px;
  }
  .guest-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    border: 1px solid rgba(255, 220, 145, .22);
    border-radius: 10px;
    padding: 12px;
    background: rgba(255,255,255,.035);
  }
  .guest-row-title {
    font-family: "Cinzel", serif;
    color: var(--gold-bright);
    font-size: .78rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    text-align: left;
  }
  .full { grid-column: 1 / -1; }
  .send-btn {
    width: 100%;
    margin-top: 16px;
    padding: 14px;
  }
  .send-btn.is-loading {
    opacity: .78;
    pointer-events: none;
  }
  .rsvp-result {
    display: none;
    border: 1px solid var(--line);
    background: rgba(255,255,255,.05);
    border-radius: 12px;
    padding: 28px 18px;
    color: var(--ink);
  }
  .rsvp-result.visible { display: block; }
  .rsvp-spinner {
    display: inline-block;
    width: 30px;
    height: 30px;
    border: 2px solid rgba(255,255,255,.24);
    border-top-color: var(--gold-bright);
    border-radius: 50%;
    animation: spin .8s linear infinite;
    margin-bottom: 14px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 20px;
    background: rgba(0,0,0,.95);
  }
  .lightbox.visible { display: flex; }
  .lightbox img {
    max-width: 100%;
    max-height: 86vh;
    border-radius: 12px;
    box-shadow: 0 20px 70px rgba(216, 180, 94, .28);
  }
  .lightbox-close {
    position: absolute;
    top: 12px;
    right: 14px;
    width: 38px;
    height: 38px;
    border: 1px solid var(--line);
    border-radius: 50%;
    background: rgba(255,255,255,.12);
    color: #fff;
    cursor: pointer;
    font-size: 1.3rem;
  }
  @media (min-width: 900px) {
    .page {
      max-width: 100%;
      padding: 30px 20px 84px;
    }
    .hero,
    .section-card,
    .rsvp-section {
      width: 75%;
      margin-left: auto;
      margin-right: auto;
    }
    .hero,
    .hero-content { min-height: 84vh; }
    .hero-bg {
      top: 45%;
      width: min(45vw, 560px);
    }
    .section-inner {
      padding: 52px 48px;
    }
    .grid { gap: 48px; }
    .gallery-track {
      justify-content: flex-start;
      flex-wrap: nowrap;
      overflow-x: auto;
    }
    .gallery-item { flex: 0 0 32%; }
    .map-wrap iframe { height: 380px; }
    .price-groups {
      grid-template-columns: 1fr;
      align-items: center;
      max-width: 430px;
    }
    .price-group { width: 100%; }
    #transfer-toggle { margin-top: 28px; }
    .rsvp-grid { gap: 22px; }
    .guest-row {
      grid-template-columns: 1fr 220px;
      align-items: end;
      gap: 14px;
    }
    .guest-row-title { grid-column: 1 / -1; text-align: center; }
    .rsvp-field input,
    .rsvp-field select,
    .rsvp-field textarea {
      text-align: center;
      font-size: 1.04rem;
      padding: 14px 16px;
    }
  }
  @media (max-width: 520px) {
    .page { padding-left: 10px; padding-right: 10px; }
    .hero { min-height: 70vh; border-radius: 12px; }
    .hero-content { min-height: 70vh; padding: 24px 14px 28px; }
    .hero-bg {
      top: 45%;
      width: min(94vw, 430px);
    }
    .hero-date {
      font-size: 1.15rem;
      margin-bottom: 2vh;
    }
    .hero-kicker {
      font-size: .78rem;
      margin-bottom: 8px;
    }
    .countdown { gap: 7px; }
    .count-box { padding: 11px 4px; }
    .rsvp-grid { grid-template-columns: 1fr; }
    .price-row { font-size: .98rem; }
  }
</style>
</head>
<body>
<%
  const heroLogo = event.custom_data?.hero_logo || event.hero_image || "/images/events/picu-xv/logo-black-mark-transparent.webp?v=20260710xv";
  const confirmLogo = event.custom_data?.confirm_logo || "/images/events/picu-xv/logo-black-glow.webp?v=20260710xv";
  const galleryImages = event.gallery && Array.isArray(event.gallery) && event.gallery.length
    ? event.gallery
    : ["/images/events/picu-xv/gallery-01.webp"];
  const mapQuery = encodeURIComponent(
    event.custom_data?.map_embed_query ||
    `${event.venue_name || "Salon Centro Comercial"}, ${event.venue_address || "25 de Mayo 966, X5963 Villa del Rosario, Córdoba, Argentina"}`
  );
  const mapLink = event.maps_url || ("https://www.google.com/maps/search/?api=1&query=" + mapQuery);
  const eventDateForCalendar = event.date || "2026-07-31";
  const eventTimeForCalendar = event.time || "21:30";
  const startLocal = new Date(`${eventDateForCalendar}T${eventTimeForCalendar}:00`);
  const endLocal = new Date(startLocal.getTime() + 5 * 60 * 60 * 1000);
  const giftAlias = event.gift_alias || "PICUXV";
  const giftCbu = event.gift_cbu || "0000003100092039184873";
  const transfer = event.custom_data?.transfer_account || {};
  const priceGroups = event.custom_data?.price_groups || [];
  function toGoogleDate(d) {
    const yyyy = d.getUTCFullYear();
    const mm = String(d.getUTCMonth() + 1).padStart(2, "0");
    const dd = String(d.getUTCDate()).padStart(2, "0");
    const hh = String(d.getUTCHours()).padStart(2, "0");
    const mi = String(d.getUTCMinutes()).padStart(2, "0");
    const ss = String(d.getUTCSeconds()).padStart(2, "0");
    return `${yyyy}${mm}${dd}T${hh}${mi}${ss}Z`;
  }
  function formatDate(dateStr) {
    if (!dateStr) return "31 de julio de 2026";
    const date = new Date(dateStr + "T00:00:00");
    const months = ["enero", "febrero", "marzo", "abril", "mayo", "junio", "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"];
    return `${date.getDate()} de ${months[date.getMonth()]} de ${date.getFullYear()}`;
  }
  const googleCalendarUrl =
    "https://calendar.google.com/calendar/render?action=TEMPLATE" +
    `&text=${encodeURIComponent(`Mis 15 - ${event.honorees || "PICU"}`)}` +
    `&dates=${toGoogleDate(startLocal)}/${toGoogleDate(endLocal)}` +
    `&details=${encodeURIComponent("Te esperamos para celebrar juntos este dia especial.")}` +
    `&location=${encodeURIComponent(event.venue_address || event.venue_name || "")}`;
%>
  <main class="page">
    <header class="hero">
      <img class="hero-bg" src="<%= heroLogo %>" alt="Logo PICU XV">
      <div class="hero-content">
        <div class="hero-kicker">INVITACI&Oacute;N &middot; MIS QUINCE</div>
        <div class="hero-date">31.07.2026</div>
      </div>
    </header>

    <section class="grid">
      <article class="section-card">
        <div class="section-inner">
          <h2 class="section-title">Cuenta regresiva</h2>
          <div class="section-divider"></div>
          <p class="section-sub">Cada segundo nos acerca a una noche para brillar.</p>
          <div class="countdown" id="countdown" data-date="<%= event.date || "" %>" data-time="<%= event.time || "" %>">
            <div class="count-box"><span class="count-number" data-unit="days">--</span><span class="count-label">Dias</span></div>
            <div class="count-box"><span class="count-number" data-unit="hours">--</span><span class="count-label">Horas</span></div>
            <div class="count-box"><span class="count-number" data-unit="minutes">--</span><span class="count-label">Minutos</span></div>
            <div class="count-box"><span class="count-number" data-unit="seconds">--</span><span class="count-label">Segundos</span></div>
          </div>
          <a class="calendar-btn" href="<%= googleCalendarUrl %>" target="_blank" rel="noopener noreferrer">Agregar al calendario</a>
        </div>
      </article>

      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifDestellos.webp" alt="Destellos" class="section-icon">
          <h2 class="section-title">&iquest;Cu&aacute;ndo?</h2>
          <div class="section-divider"></div>
          <div class="info-list">
            <div><%= formatDate(event.date) %></div>
            <div><%= event.time || "21:30" %> hs</div>
          </div>
        </div>
      </article>

      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifMapa.webp" alt="Mapa" class="section-icon">
          <h2 class="section-title">&iquest;D&oacute;nde?</h2>
          <div class="section-divider"></div>
          <div class="info-list">
            <div><strong>Lugar:</strong> <%= event.venue_name || "Salon Centro Comercial" %></div>
            <div><strong>Direcci&oacute;n:</strong> <%= event.venue_address || "25 de Mayo 972, Villa el Rosario, Cordoba" %></div>
          </div>
        </div>
      </article>

      <% if (sections && sections.location) { %>
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifMapa.webp" alt="Mapa" class="section-icon">
          <h2 class="section-title">C&oacute;mo llegar</h2>
          <div class="section-divider"></div>
          <div class="map-wrap">
            <iframe title="Mapa del evento" src="https://www.google.com/maps?q=<%= mapQuery %>&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
          <a class="map-btn" href="<%= mapLink %>" target="_blank" rel="noopener noreferrer">Abrir Google Maps</a>
        </div>
      </article>
      <% } %>

      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifRevista.webp" alt="Tarjeta" class="section-icon">
          <h2 class="section-title">Valor de la tarjeta</h2>
          <div class="section-divider"></div>
          <div class="price-groups">
            <% priceGroups.forEach(function(group) { %>
              <div class="price-group">
                <h3 class="price-heading"><%= group.title %></h3>
                <% group.items.forEach(function(item) { %>
                  <div class="price-row"><span><%= item.label %></span><span><%= item.value %></span></div>
                <% }) %>
              </div>
            <% }) %>
          </div>
          <button type="button" class="gift-toggle" id="transfer-toggle">Ver datos para la transferencia</button>
          <div class="transfer-box" id="transfer-box">
            <div><strong>Alias:</strong> <%= transfer.alias || "LauraNF" %></div>
            <div><strong>CBU:</strong> <%= transfer.cbu || "0110556830055606038251" %></div>
            <div><strong>Titular:</strong> <%= transfer.holder || "Ferreyra Laura Nadir" %></div>
            <div><strong>Banco:</strong> <%= transfer.bank || "Banco Nacion" %></div>
            <div style="margin-top:10px;font-style:italic;"><%= transfer.receipt_note || "Enviar comprobante a 3573457710" %></div>
          </div>
        </div>
      </article>

      <% if (sections && sections.dress_code) { %>
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifDiamante.webp" alt="Diamante" class="section-icon">
          <h2 class="section-title">Dress Code</h2>
          <div class="section-divider"></div>
          <div class="info-list">
            <div><strong><%= event.dress_code || "Glam Nocturno" %></strong></div>
          </div>
        </div>
      </article>
      <% } %>

      <% if (sections && sections.gallery) { %>
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifCamara.webp" alt="Camara" class="section-icon">
          <h2 class="section-title">Galer&iacute;a</h2>
          <div class="section-divider"></div>
          <div class="gallery-track">
            <% galleryImages.forEach(function(photo) { %>
              <div class="gallery-item" data-photo="<%= photo %>">
                <img src="<%= photo %>" alt="Foto de galeria del evento">
              </div>
            <% }) %>
          </div>
        </div>
      </article>
      <% } %>

      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifStar.webp" alt="Estrella" class="section-icon">
          <div class="section-divider"></div>
          <p class="quote-text"><%= event.quote_message || "Fuerte y valiente para soñar, libre para vivir" %></p>
        </div>
      </article>

      <% if (sections && sections.gifts) { %>
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifRegalo.webp" alt="Regalo" class="section-icon">
          <h2 class="section-title">Regalo</h2>
          <div class="section-divider"></div>
          <p class="section-sub"><%= event.gift_message || "Con tu presencia alcanza, pero si deseas hacerme un regalo sera recibido con mucho amor." %></p>
          <button type="button" class="gift-toggle" id="gift-toggle">Ver datos para regalo</button>
          <div class="gift-box" id="gift-box">
            <div><strong>Alias:</strong> <%= giftAlias %></div>
            <div><strong>CBU:</strong> <%= giftCbu %></div>
            <div><strong>Titular:</strong> <%= event.gift_holder || "Ferreyra Laura Nadir" %></div>
            <div>Mercado Pago</div>
          </div>
        </div>
      </article>
      <% } %>
    </section>

    <section class="rsvp-section" id="rsvp">
      <div class="section-logo-wrap">
        <img src="<%= confirmLogo %>" alt="" class="section-logo-halo" aria-hidden="true">
        <img src="<%= confirmLogo %>" alt="Logo PICU XV" class="section-logo">
      </div>
      <h2 class="section-title">Confirmar asistencia</h2>
      <div class="section-divider"></div>
      <p class="section-sub">&iexcl;Quiero saber si vas a estar! Complet&aacute; tus datos ac&aacute; abajo.</p>
      <form action="/api/<%= event.slug %>/rsvp" method="post" id="rsvp-form">
        <div class="rsvp-grid">
          <input type="hidden" id="contact_name" name="contact_name" value="Confirmacion Picu">
          <textarea id="people_names" name="people_names" hidden></textarea>
          <div class="rsvp-field">
            <label for="people_count">&iquest;Cu&aacute;ntos vienen?</label>
            <input type="text" id="people_count" name="people_count" inputmode="numeric" pattern="[0-9]*" value="1" required>
          </div>
          <div class="rsvp-field">
            <label for="status">Asistencia</label>
            <select id="status" name="status">
              <option value="confirmed">Voy / Vamos</option>
              <option value="declined">No puedo ir</option>
            </select>
          </div>
          <div class="rsvp-field full">
            <label>Nombre y apellido / Tipo de invitaci&oacute;n</label>
            <div class="guest-list" id="guest-list"></div>
          </div>
          <div class="rsvp-field full">
            <label for="food_preferences">Preferencias de comida</label>
            <textarea id="food_preferences" name="food_preferences" placeholder="Aclarar si se prefiere menu vegetariano o celiaco"></textarea>
          </div>
          <% if (sections && sections.music) { %>
            <div class="rsvp-field full">
              <label for="song_suggestions">Temas que no pueden faltar</label>
              <textarea id="song_suggestions" name="song_suggestions" placeholder="Decime que canciones queres bailar"></textarea>
            </div>
          <% } %>
          <div class="rsvp-field full">
            <label for="comments">Mensajito para m&iacute;</label>
            <textarea id="comments" name="comments"></textarea>
          </div>
        </div>
        <button type="submit" class="send-btn">Enviar confirmaci&oacute;n</button>
      </form>
      <div class="rsvp-result" id="rsvp-result" aria-live="polite"></div>
    </section>
  </main>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close" aria-label="Cerrar">&times;</button>
    <img src="" alt="Foto ampliada de la galeria" id="lightbox-image">
  </div>

  <script>
    (function() {
      const qs = new URLSearchParams(window.location.search);
      if (qs.get("rsvp") === "ok") {
        qs.delete("rsvp");
        const clean = window.location.pathname + (qs.toString() ? "?" + qs.toString() : "");
        window.history.replaceState({}, "", clean);
        showRsvpResult(false);
      }

      const countdown = document.getElementById("countdown");
      if (countdown) {
        const dateStr = countdown.getAttribute("data-date");
        const timeStr = countdown.getAttribute("data-time") || "00:00";
        if (dateStr) {
          const target = new Date(dateStr + "T" + timeStr + ":00");
          function update() {
            const now = new Date();
            let diff = target.getTime() - now.getTime();
            if (diff < 0) diff = 0;
            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
            const minutes = Math.floor((diff / (1000 * 60)) % 60);
            const seconds = Math.floor((diff / 1000) % 60);
            const set = function(unit, value) {
              const node = countdown.querySelector('[data-unit="' + unit + '"]');
              if (node) node.textContent = String(value).padStart(2, "0");
            };
            set("days", days);
            set("hours", hours);
            set("minutes", minutes);
            set("seconds", seconds);
          }
          update();
          setInterval(update, 1000);
        }
      }

      function bindToggle(buttonId, boxId, openText, closeText) {
        const button = document.getElementById(buttonId);
        const box = document.getElementById(boxId);
        if (!button || !box) return;
        button.addEventListener("click", function() {
          box.classList.toggle("visible");
          button.textContent = box.classList.contains("visible") ? closeText : openText;
        });
      }
      bindToggle("gift-toggle", "gift-box", "Ver datos para regalo", "Ocultar datos para regalo");
      bindToggle("transfer-toggle", "transfer-box", "Ver datos para la transferencia", "Ocultar datos para la transferencia");

      const rsvpForm = document.getElementById("rsvp-form");
      const peopleCount = document.getElementById("people_count");
      const guestList = document.getElementById("guest-list");
      const hiddenPeopleNames = document.getElementById("people_names");
      const hiddenContactName = document.getElementById("contact_name");
      const rsvpResult = document.getElementById("rsvp-result");
      const sendBtn = rsvpForm ? rsvpForm.querySelector(".send-btn") : null;
      function getGuestValues() {
        if (!guestList) return [];
        return Array.from(guestList.querySelectorAll(".guest-row")).map(function(row) {
          const name = row.querySelector(".guest-name");
          const type = row.querySelector(".guest-type");
          return {
            name: name ? name.value.trim() : "",
            type: type ? type.value : "Mayor"
          };
        });
      }
      function renderGuestRows() {
        if (!peopleCount || !guestList) return;
        const current = getGuestValues();
        const digits = peopleCount.value.replace(/\D/g, "");
        if (peopleCount.value !== digits) peopleCount.value = digits;
        const total = Math.max(1, Math.min(30, Number(digits) || 1));
        if (Number(digits) > 30) peopleCount.value = "30";
        guestList.innerHTML = "";
        for (let index = 0; index < total; index++) {
          const previous = current[index] || {};
          const row = document.createElement("div");
          row.className = "guest-row";
          row.innerHTML =
            '<div class="guest-row-title">Invitado ' + (index + 1) + '</div>' +
            '<div class="rsvp-field">' +
              '<label>Nombre y apellido</label>' +
              '<input class="guest-name" type="text" required autocomplete="name" value="' + (previous.name || "").replace(/"/g, "&quot;") + '">' +
            '</div>' +
            '<div class="rsvp-field">' +
              '<label>Tipo de invitaci&oacute;n</label>' +
              '<select class="guest-type" required>' +
                '<option value="Mayor">Mayor</option>' +
                '<option value="Menor">Menor</option>' +
                '<option value="Brindis">Brindis</option>' +
              '</select>' +
            '</div>';
          const type = row.querySelector(".guest-type");
          if (type && previous.type) type.value = previous.type;
          guestList.appendChild(row);
        }
      }
      function normalizePeopleCount() {
        if (!peopleCount) return;
        const total = Math.max(1, Math.min(30, Number(peopleCount.value) || 1));
        peopleCount.value = String(total);
        renderGuestRows();
      }
      function syncGuestFields() {
        const guests = getGuestValues();
        if (hiddenPeopleNames) {
          hiddenPeopleNames.value = guests
            .filter(function(guest) { return guest.name; })
            .map(function(guest) { return guest.name + " [ " + guest.type.toUpperCase() + " ]"; })
            .join("\n");
        }
        if (hiddenContactName) {
          hiddenContactName.value = guests.find(function(guest) { return guest.name; })?.name || "Confirmacion Picu";
        }
      }
      if (peopleCount) {
        peopleCount.addEventListener("input", renderGuestRows);
        peopleCount.addEventListener("change", normalizePeopleCount);
        peopleCount.addEventListener("blur", normalizePeopleCount);
      }
      renderGuestRows();
      function showRsvpResult(loading) {
        if (!rsvpForm || !rsvpResult) return;
        rsvpForm.style.display = "none";
        rsvpResult.classList.add("visible");
        rsvpResult.innerHTML = loading
          ? '<span class="rsvp-spinner"></span><p class="section-sub" style="margin:0;">Enviando confirmacion...</p>'
          : '<h3 class="section-title" style="font-size:1.35rem;margin-bottom:10px;">Gracias por confirmar</h3><p class="section-sub" style="margin:0;">&iexcl;La vamos a pasar muy bien!</p>';
      }
      if (rsvpForm) {
        rsvpForm.addEventListener("submit", async function(e) {
          e.preventDefault();
          normalizePeopleCount();
          syncGuestFields();
          if (sendBtn) sendBtn.classList.add("is-loading");
          showRsvpResult(true);
          try {
            const response = await fetch(rsvpForm.action, {
              method: "POST",
              body: new URLSearchParams(new FormData(rsvpForm)),
              headers: { "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8" }
            });
            if (!response.ok) throw new Error("No se pudo enviar");
            setTimeout(function() { showRsvpResult(false); }, 900);
          } catch (error) {
            rsvpForm.style.display = "";
            rsvpResult.classList.remove("visible");
            rsvpResult.innerHTML = "";
            if (sendBtn) sendBtn.classList.remove("is-loading");
            window.alert("No pudimos enviar la confirmacion. Intenta nuevamente.");
          }
        });
      }

      const lightbox = document.getElementById("lightbox");
      const lightboxImage = document.getElementById("lightbox-image");
      const lightboxClose = document.getElementById("lightbox-close");
      document.querySelectorAll(".gallery-item").forEach(function(item) {
        item.addEventListener("click", function() {
          const photo = item.getAttribute("data-photo");
          if (!photo || !lightbox || !lightboxImage) return;
          lightboxImage.src = photo;
          lightbox.classList.add("visible");
        });
      });
      if (lightboxClose && lightbox) {
        lightboxClose.addEventListener("click", function() {
          lightbox.classList.remove("visible");
        });
        lightbox.addEventListener("click", function(e) {
          if (e.target === lightbox) lightbox.classList.remove("visible");
        });
      }
    })();
  </script>
</body>
</html>

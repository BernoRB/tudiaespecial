<!DOCTYPE html>
<html lang="es-AR">
<head>
<%- include('../partials/meta-tags', {
  title: (event.honorees || "Bautismo") + " · Invitación Digital",
  description: (event.honorees || "Bautismo") + " - Invitación digital con confirmación de asistencia, ubicación y galería. Servicio en Argentina.",
  keywords: "invitación digital bautismo, bautismo, " + (event.honorees || "") + ", Argentina",
  url: "https://tudiaespecial.com" + req.originalUrl,
  type: "article"
}) %>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
<link rel="icon" type="image/png" href="/images/favicon.png">
<style>
  :root{--bg:#f7f6f0;--card:#fffdf7;--ink:#39483c;--muted:#75806d;--sage:#9cac8f;--cream:#efe6d4;--gold:#c6a760;--line:rgba(57,72,60,.18);--shadow:0 22px 60px rgba(57,72,60,.14)}
  *{box-sizing:border-box} body{margin:0;font-family:"Montserrat",sans-serif;background:linear-gradient(180deg,#eef2e7,#fbfaf4 44%,#f3f0e8);color:var(--ink)}
  .page{max-width:1120px;margin:0 auto;padding:22px 16px 60px}.hero{min-height:86vh;position:relative;overflow:hidden;border-radius:8px;background:#d9dfd0;box-shadow:var(--shadow)}
  .hero img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}.hero:after{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(33,47,36,.82),rgba(33,47,36,.4),rgba(33,47,36,.16))}
  .hero-content{position:relative;z-index:1;min-height:86vh;display:flex;flex-direction:column;justify-content:center;align-items:flex-start;text-align:left;color:#fff;padding:44px 28px;max-width:720px}.kicker{letter-spacing:.24em;text-transform:uppercase;font-size:.78rem;color:#efe6d4;font-weight:600}h1{font-family:"Fraunces",serif;font-size:clamp(3.2rem,12vw,6.2rem);line-height:1;margin:18px 0 10px;font-weight:600}.hero-message{font-family:"Fraunces",serif;font-size:clamp(1.2rem,4vw,2rem);font-style:italic;margin:0;color:#fff7df}.countdown{position:absolute;z-index:2;right:26px;bottom:26px;display:grid;grid-template-columns:repeat(4,68px);gap:8px}.count-box{background:rgba(255,253,247,.9);border:1px solid rgba(255,255,255,.65);padding:11px 4px;text-align:center;color:var(--ink)}.count-box strong{display:block;font-family:"Fraunces",serif;font-size:1.7rem}.count-box span{font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
  .grid{display:grid;gap:24px;margin-top:24px}.card{background:var(--card);border:1px solid var(--line);border-radius:8px;box-shadow:var(--shadow);padding:40px 24px;text-align:center}.section-title{font-family:"Fraunces",serif;font-size:2rem;margin:0 0 10px}.divider{width:72px;height:1px;background:var(--gold);margin:0 auto 24px}.event-pair{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}.mini{border:1px solid var(--line);background:#faf8ef;padding:18px;text-align:left}.mini h3{font-family:"Fraunces",serif;margin:0 0 10px;font-size:1.35rem}.mini p{margin:7px 0;color:var(--muted);line-height:1.55}.calendar-btn,.map-btn,.send-btn{display:inline-block;margin-top:18px;background:var(--ink);color:#fff;text-decoration:none;border:0;border-radius:2px;padding:12px 18px;text-transform:uppercase;letter-spacing:.14em;font-size:.72rem;font-weight:600;cursor:pointer}.map-wrap{overflow:hidden;border:1px solid var(--line);border-radius:8px}.map-wrap iframe{width:100%;height:340px;border:0;display:block}.gallery{display:grid;grid-auto-flow:column;grid-auto-columns:74%;gap:12px;overflow-x:auto;scroll-snap-type:x mandatory;padding:4px}.photo{aspect-ratio:4/5;overflow:hidden;scroll-snap-align:start;cursor:pointer;background:#e8eadf}.photo img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .35s}.photo:hover img{transform:scale(1.04)}.quote{font-family:"Fraunces",serif;font-size:1.35rem;line-height:1.8;font-style:italic;color:#485842;margin:0}.sub{color:var(--muted);line-height:1.65}.rsvp-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;text-align:left}.field.full{grid-column:1/-1}.field label{display:block;margin-bottom:6px;font-size:.7rem;letter-spacing:.13em;text-transform:uppercase;color:var(--muted);font-weight:600}.field input,.field select,.field textarea{width:100%;border:1px solid var(--line);border-radius:2px;padding:12px 14px;font:inherit;color:var(--ink);background:#fff}.field textarea{min-height:78px;resize:vertical}.send-btn{width:100%;margin-top:16px}.lightbox{display:none;position:fixed;inset:0;background:rgba(28,39,30,.93);z-index:50;align-items:center;justify-content:center;padding:18px}.lightbox.visible{display:flex}.lightbox img{max-width:100%;max-height:86vh;border-radius:8px}.close{position:absolute;top:14px;right:14px;width:40px;height:40px;border:0;background:rgba(255,255,255,.18);color:#fff;font-size:1.5rem;cursor:pointer}
  @media(min-width:900px){.page{max-width:100%;padding:34px 22px 84px}.hero,.card{width:76%;margin-left:auto;margin-right:auto}.hero-content{padding-left:64px}.gallery{grid-auto-columns:30%}.card{padding:54px 48px}.rsvp-grid{text-align:center}}@media(max-width:720px){.event-pair,.rsvp-grid{grid-template-columns:1fr}.hero{border-radius:0;margin:0 -16px}.hero-content{align-items:center;text-align:center}.countdown{left:50%;right:auto;transform:translateX(-50%);grid-template-columns:repeat(4,56px)}.count-box strong{font-size:1.35rem}}
</style>
</head>
<body>
<%
  const sectionsData = typeof sections !== "undefined" ? sections : (event.sections || {});
  const ceremonies = event.ceremonies || {};
  const church = ceremonies.church || {};
  const party = ceremonies.party || {};
  const hasChurch = church.enabled || church.name || church.time || church.address;
  const hasParty = party.enabled || party.name || party.time || party.address;
  const blocks = [];
  if (hasChurch) blocks.push({ label: "Iglesia", name: church.name || "Iglesia", time: church.time || "", address: church.address || "", date: church.date || event.date || "" });
  if (hasParty) blocks.push({ label: "Recepción", name: party.name || event.venue_name || "Recepción", time: party.time || "", address: party.address || event.venue_address || "", date: party.date || event.date || "" });
  if (!blocks.length) blocks.push({ label: "Encuentro", name: event.venue_name || "Lugar del encuentro", time: event.time || "", address: event.venue_address || "", date: event.date || "" });
  const mapAddress = (hasParty && party.address) || (hasChurch && church.address) || event.venue_address || event.venue_name || "Buenos Aires";
  const heroImage = event.hero_image || "https://images.unsplash.com/photo-1516627145497-ae6968895b74?q=80&w=1200&auto=format&fit=crop";
  const galleryImages = event.gallery && event.gallery.length ? event.gallery : [
    "https://images.unsplash.com/photo-1523438885200-e635ba2c371e?q=80&w=900&auto=format&fit=crop",
    "https://images.unsplash.com/photo-1544126562-807ade215a0b?q=80&w=900&auto=format&fit=crop",
    "https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?q=80&w=900&auto=format&fit=crop"
  ];
  const mainTime = event.time || party.time || church.time || "12:00";
  function formatDate(dateStr){ if(!dateStr) return "Domingo 16 de agosto de 2026"; const d = new Date(dateStr + "T00:00:00"); const m = ["enero","febrero","marzo","abril","mayo","junio","julio","agosto","septiembre","octubre","noviembre","diciembre"]; return `${d.getDate()} de ${m[d.getMonth()]} de ${d.getFullYear()}`; }
  function toGoogleDate(d){ return `${d.getUTCFullYear()}${String(d.getUTCMonth()+1).padStart(2,"0")}${String(d.getUTCDate()).padStart(2,"0")}T${String(d.getUTCHours()).padStart(2,"0")}${String(d.getUTCMinutes()).padStart(2,"0")}00Z`; }
  const start = new Date(`${event.date || "2026-08-16"}T${mainTime}:00`);
  const end = new Date(start.getTime() + 3 * 60 * 60 * 1000);
  const calendarUrl = "https://calendar.google.com/calendar/render?action=TEMPLATE" + `&text=${encodeURIComponent("Bautismo de " + (event.honorees || ""))}` + `&dates=${toGoogleDate(start)}/${toGoogleDate(end)}` + `&details=${encodeURIComponent("Te esperamos para compartir este día tan especial.")}` + `&location=${encodeURIComponent(mapAddress)}`;
%>
<main class="page">
  <header class="hero"><img src="<%= heroImage %>" alt="Foto principal del bautismo"><div class="hero-content"><div class="kicker">Bautismo</div><h1><%= event.honorees || "Clara" %></h1><p class="hero-message"><%= event.hero_message || "Un día para guardar en el corazón" %></p></div><div class="countdown" id="countdown" data-date="<%= event.date || '' %>" data-time="<%= mainTime %>"><div class="count-box"><strong data-unit="days">--</strong><span>Días</span></div><div class="count-box"><strong data-unit="hours">--</strong><span>Horas</span></div><div class="count-box"><strong data-unit="minutes">--</strong><span>Min</span></div><div class="count-box"><strong data-unit="seconds">--</strong><span>Seg</span></div></div></header>
  <section class="grid">
    <article class="card"><h2 class="section-title">¿Cuándo?</h2><div class="divider"></div><div class="event-pair"><% blocks.forEach(function(item){ %><div class="mini"><h3><%= item.label %></h3><p><%= formatDate(item.date || event.date) %></p><% if (item.time) { %><p><strong><%= item.time %> hs</strong></p><% } %></div><% }) %></div><a class="calendar-btn" href="<%= calendarUrl %>" target="_blank" rel="noopener noreferrer">Agregar al calendario</a></article>
    <article class="card"><h2 class="section-title">¿Dónde?</h2><div class="divider"></div><div class="event-pair"><% blocks.forEach(function(item){ %><div class="mini"><h3><%= item.label %></h3><p><strong><%= item.name %></strong></p><% if (item.address) { %><p><%= item.address %></p><% } %></div><% }) %></div></article>
    <% if (sectionsData.location) { %><article class="card"><h2 class="section-title">Cómo llegar</h2><div class="divider"></div><div class="map-wrap"><iframe title="Mapa del bautismo" src="https://www.google.com/maps?q=<%= encodeURIComponent(mapAddress) %>&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe></div><a class="map-btn" href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(mapAddress) %>" target="_blank" rel="noopener noreferrer">Abrir mapa</a></article><% } %>
    <% if (sectionsData.gallery) { %><article class="card"><h2 class="section-title">Galería</h2><div class="divider"></div><div class="gallery"><% galleryImages.forEach(function(photo){ %><div class="photo" data-photo="<%= photo %>"><img src="<%= photo %>" alt="Foto de galería"></div><% }) %></div></article><% } %>
    <article class="card"><p class="quote"><%= event.quote_message || "Que la fe, la ternura y el amor de quienes te rodean acompañen siempre tus pasos." %></p></article>
  </section>
  <section class="card" style="margin-top:24px"><h2 class="section-title">Confirmar asistencia</h2><div class="divider"></div><p class="sub">Completá tus datos para confirmar si vas a acompañarnos.</p><form action="/api/<%= event.slug %>/rsvp" method="post"><div class="rsvp-grid"><div class="field full"><label for="contact_name">Nombre de quien confirma</label><input id="contact_name" name="contact_name" required></div><div class="field"><label for="people_count">¿Cuántos vienen?</label><input type="number" id="people_count" name="people_count" min="1" value="1" required></div><div class="field"><label for="status">Asistencia</label><select id="status" name="status"><option value="confirmed">Voy / Vamos</option><option value="declined">No puedo ir</option></select></div><div class="field full"><label for="people_names">Nombre y apellido de acompañantes</label><textarea id="people_names" name="people_names"></textarea></div><div class="field full"><label for="comments">Mensaje</label><textarea id="comments" name="comments"></textarea></div></div><button class="send-btn" type="submit">Enviar confirmación</button></form></section>
</main>
<div class="lightbox" id="lightbox"><button class="close" id="close" aria-label="Cerrar">×</button><img id="lightbox-image" alt="Foto ampliada"></div>
<script>
(function(){const qs=new URLSearchParams(location.search);if(qs.get("rsvp")==="ok"){alert("Gracias por confirmar tu asistencia.");qs.delete("rsvp");history.replaceState({},"",location.pathname+(qs.toString()?"?"+qs.toString():""));}const el=document.getElementById("countdown");if(el&&el.dataset.date){const target=new Date(el.dataset.date+"T"+(el.dataset.time||"00:00")+":00");function tick(){let diff=Math.max(0,target.getTime()-Date.now());const set=(u,v)=>{const n=el.querySelector('[data-unit="'+u+'"]');if(n)n.textContent=String(v).padStart(2,"0")};set("days",Math.floor(diff/86400000));set("hours",Math.floor(diff/3600000)%24);set("minutes",Math.floor(diff/60000)%60);set("seconds",Math.floor(diff/1000)%60)}tick();setInterval(tick,1000)}const lightbox=document.getElementById("lightbox");const image=document.getElementById("lightbox-image");document.querySelectorAll(".photo").forEach(p=>p.addEventListener("click",()=>{image.src=p.dataset.photo;lightbox.classList.add("visible")}));document.getElementById("close").addEventListener("click",()=>lightbox.classList.remove("visible"));lightbox.addEventListener("click",e=>{if(e.target===lightbox)lightbox.classList.remove("visible")});})();
</script>
</body>
</html>

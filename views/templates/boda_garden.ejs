<!DOCTYPE html>
<html lang="es-AR">
<head>
<%- include('../partials/meta-tags', {
  title: (event.honorees || "Nuestra boda") + " · Invitación Digital",
  description: (event.honorees || "Nuestra boda") + " - " + (event.venue_name || "") + ". Invitación digital con confirmación de asistencia, ubicación y agenda. Servicio en Argentina.",
  keywords: "invitación digital bodas, " + (event.honorees || "") + ", " + (event.venue_name || "") + ", Argentina",
  url: "https://tudiaespecial.com" + req.originalUrl,
  type: "article"
}) %>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
<link rel="icon" type="image/png" href="/images/favicon.png">
<style>
    :root {
      --bg: #f5f8f2;
      --card: #ffffff;
      --ink: #2d4a3e;
      --muted: #6b8e7a;
      --accent: #6b8e23;
      --accent-soft: rgba(107, 142, 35, 0.15);
      --line: rgba(107, 142, 35, 0.4);
      --shadow: 0 18px 42px rgba(107, 142, 35, 0.15);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Lato", sans-serif;
      background: var(--bg);
      color: var(--ink);
    }
    .page {
      width: 100%;
      max-width: 1120px;
      margin: 0 auto;
      padding: 18px 16px 60px;
      text-align: center;
    }
    .hero {
      position: relative;
      border-radius: 16px;
      overflow: hidden;
      min-height: 90vh;
      box-shadow: var(--shadow);
      margin-bottom: 24px;
      background: #f5f8f2;
    }
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to top, rgba(45, 74, 62, 0.85), rgba(45, 74, 62, 0.3) 40%, rgba(45, 74, 62, 0.5));
      z-index: 1;
    }
    .hero img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      position: absolute;
      inset: 0;
    }
    .hero-content {
      position: relative;
      z-index: 2;
      color: #fff;
      min-height: 90vh;
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 8px;
      text-align: center;
    }
    .hero-name {
      font-family: "Cormorant Garamond", serif;
      font-weight: 700;
      font-size: clamp(3rem, 12vw, 5rem);
      margin: 0;
      line-height: 1;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.8);
    }
    .hero-title {
      font-family: "Cormorant Garamond", serif;
      font-weight: 400;
      font-style: italic;
      font-size: clamp(2rem, 5vw, 2.5rem);
      margin: 0;
      opacity: 0.95;
      text-shadow: 2px 2px 6px rgba(0, 0, 0, 0.8);
    }

    .hero-countdown {
      position: absolute;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 3;
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 4px;
      text-align: center;
    }
    .hero-count-number {
      font-family: "Cormorant Garamond", serif;
      font-weight: 700;
      font-size: 2.5rem;
      color: #c9b896;
      line-height: 1;
      text-shadow: 2px 2px 6px rgba(0, 0, 0, 0.8);
    }
    .hero-count-separator {
      font-family: "Cormorant Garamond", serif;
      font-weight: 700;
      font-size: 2.5rem;
      color: #c9b896;
      line-height: 1;
      opacity: 0.5;
      text-shadow: 2px 2px 6px rgba(0, 0, 0, 0.8);
    }

    .grid {
      display: grid;
      gap: 24px;
    }
    .section-card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 12px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .section-inner {
      padding: 40px 28px;
    }
    .section-title {
      font-family: "Cormorant Garamond", serif;
      font-weight: 600;
      font-size: 1.65rem;
      margin: 0 0 14px;
      color: var(--ink);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .section-sub {
      margin: 0 0 16px;
      color: var(--muted);
      font-size: 1.08rem;
      line-height: 1.6;
    }
    .section-divider {
      width: 80px;
      height: 1px;
      background: var(--accent);
      margin: 0 auto 20px auto;
      border-radius: 0.5px;
    }
    .section-icon {
      width: 72px;
      height: 72px;
      margin: 0 auto 22px auto;
      object-fit: contain;
      display: block;
      background: #3d5a4e;
      border-radius: 50%;
      padding: 8px;
      border: 2px solid var(--accent);
    }

    .info-list {
      display: grid;
      gap: 14px;
      margin-top: 14px;
      color: var(--muted);
      font-size: 1.1rem;
      line-height: 1.65;
      text-align: center;
    }
    .calendar-btn {
      margin-top: 12px;
      border: none;
      background: var(--accent);
      color: #fff;
      border-radius: 6px;
      padding: 11px 16px;
      font-size: 0.88rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      font-family: "Cormorant Garamond", serif;
      font-weight: 600;
    }

    .map-wrap {
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid var(--line);
      min-height: 250px;
      background: #f5f8f2;
    }
    .map-wrap iframe {
      width: 100%;
      height: 250px;
      border: 0;
      display: block;
    }

    .gallery-track {
      display: flex;
      overflow-x: auto;
      gap: 10px;
      padding: 2px 2px 4px;
      scroll-snap-type: x mandatory;
    }
    .gallery-item {
      flex: 0 0 72%;
      border-radius: 8px;
      overflow: hidden;
      border: 3px solid var(--accent);
      box-shadow: 0 12px 32px rgba(107, 142, 35, 0.25);
      cursor: pointer;
      scroll-snap-align: start;
      background: #f5f8f2;
      aspect-ratio: 4/5;
    }
    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .gift-toggle {
      width: 100%;
      border: 1px solid var(--line);
      background: var(--accent-soft);
      border-radius: 8px;
      color: var(--accent);
      padding: 14px 18px;
      font-weight: 600;
      cursor: pointer;
      text-align: center;
      font-family: "Cormorant Garamond", serif;
      letter-spacing: 0.05em;
      font-size: 1.1rem;
    }
    .gift-box {
      display: none;
      margin-top: 12px;
      padding: 16px;
      border: 1px solid var(--line);
      border-radius: 8px;
      color: var(--muted);
      font-size: 0.95rem;
      background: #f5f8f2;
      line-height: 1.6;
      text-align: center;
    }
    .gift-box.visible { display: block; }

    .rsvp-section {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 12px;
      box-shadow: var(--shadow);
      padding: 28px 24px 32px;
    }
    .rsvp-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .rsvp-field label {
      display: block;
      margin-bottom: 5px;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
    }
    .rsvp-field input,
    .rsvp-field select,
    .rsvp-field textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 10px 12px;
      font: inherit;
      font-size: 0.92rem;
      color: var(--ink);
      background: #fff;
    }
    .rsvp-field input::placeholder,
    .rsvp-field textarea::placeholder {
      opacity: 0.5;
    }
    .rsvp-field textarea {
      min-height: 72px;
      resize: vertical;
    }
    .full { grid-column: 1 / -1; }
    .send-btn {
      margin-top: 16px;
      width: 100%;
      border: none;
      background: var(--accent);
      color: #fff;
      border-radius: 6px;
      padding: 14px;
      font-size: 0.88rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      cursor: pointer;
      font-weight: 700;
      font-family: "Cormorant Garamond", serif;
    }

    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(45, 74, 62, 0.95);
      z-index: 9999;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .lightbox.visible { display: flex; }
    .lightbox img {
      max-width: 100%;
      max-height: 85vh;
      border-radius: 12px;
      box-shadow: 0 20px 60px rgba(107, 142, 35, 0.3);
    }
    .lightbox-close {
      position: absolute;
      top: 12px;
      right: 14px;
      border: 0;
      background: rgba(107, 142, 35, 0.2);
      color: #fff;
      width: 38px;
      height: 38px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 1.3rem;
    }

    @media (min-width: 900px) {
      .page { 
        padding: 30px 20px 80px; 
        max-width: 100%;
      }
      .hero {
        width: 75%;
        margin: 0 auto;
      }
      .hero, .hero-content { min-height: 85vh; }
      .hero-content { padding: 48px 48px; }
      .hero-countdown {
        bottom: 60px;
        gap: 24px;
      }
      .hero-count-number {
        font-size: 2.5rem;
      }
      .hero-count-separator {
        font-size: 2.5rem;
      }
      .grid {
        grid-template-columns: 1fr;
        gap: 48px;
      }
      .section-card {
        width: 75%;
        margin: 0 auto;
      }
      .section-inner { 
        padding: 52px 48px; 
        text-align: center;
      }
      .section-title {
        font-size: 2rem;
        margin-bottom: 16px;
      }
      .section-sub {
        font-size: 1.2rem;
        margin-bottom: 24px;
      }
      .section-divider {
        width: 100px;
        height: 2px;
        margin: 0 auto 32px auto;
      }
      .info-list {
        font-size: 1.2rem;
        gap: 16px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .gallery-track {
        justify-content: center;
      }
      .gallery-item { 
        flex-basis: 30%; 
        aspect-ratio: 4/5; 
      }
      .gallery-item img { height: 100%; }
      .map-wrap iframe { height: 380px; }
      .rsvp-section { 
        padding: 32px 28px 36px; 
        width: 75%;
        margin: 24px auto 0;
      }
      .rsvp-grid { 
        gap: 24px;
        text-align: center;
      }
      .rsvp-field label {
        font-size: 0.85rem;
        text-align: center;
      }
      .rsvp-field input,
      .rsvp-field select,
      .rsvp-field textarea {
        font-size: 1.05rem;
        padding: 14px 16px;
        text-align: center;
      }
      .send-btn {
        font-size: 0.9rem;
        padding: 16px;
      }
    }
  </style>
</head>
<body>
  <%
    const heroImage =
      event.hero_image ||
      "https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=1400&q=80";
    const galleryImages =
      event.gallery && Array.isArray(event.gallery) && event.gallery.length
        ? event.gallery
        : [
            "https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=1000&q=80",
            "https://images.unsplash.com/photo-1607190074257-dd4b7af0309f?auto=format&fit=crop&w=1000&q=80",
            "https://images.unsplash.com/photo-1520854221256-17451cc331bf?auto=format&fit=crop&w=1000&q=80",
          ];
    const gallery2Images =
      event.gallery2 && Array.isArray(event.gallery2) && event.gallery2.length
        ? event.gallery2
        : [
            "https://images.unsplash.com/photo-1591604442449-ecc9943efabf?auto=format&fit=crop&w=1000&q=80",
            "https://plus.unsplash.com/premium_photo-1664530453104-68710b5f517c?auto=format&fit=crop&w=1000&q=80",
            "https://plus.unsplash.com/premium_photo-1664297755132-af79f91c26df?auto=format&fit=crop&w=1000&q=80",
            "https://img.freepik.com/fotos-premium/imagen-emocional-pareja-recien-casada-pie-campo-besandose-rio-fondo-objetivos-pareja_232070-4172.jpg"
          ];
    const mapsQuery = encodeURIComponent(event.venue_address || event.venue_name || "Buenos Aires");
    const giftCbu = event.gift_cbu || "0000000000000000000000";
    const giftAlias = event.gift_alias || "boda.alias";
    const eventDateForCalendar = event.date || "2026-11-14";
    const eventTimeForCalendar = event.time || "19:30";
    const startLocal = new Date(`${eventDateForCalendar}T${eventTimeForCalendar}:00`);
    const endLocal = new Date(startLocal.getTime() + 5 * 60 * 60 * 1000);
    function toGoogleDate(d) {
      const yyyy = d.getUTCFullYear();
      const mm = String(d.getUTCMonth() + 1).padStart(2, "0");
      const dd = String(d.getUTCDate()).padStart(2, "0");
      const hh = String(d.getUTCHours()).padStart(2, "0");
      const mi = String(d.getUTCMinutes()).padStart(2, "0");
      const ss = String(d.getUTCSeconds()).padStart(2, "0");
      return `${yyyy}${mm}${dd}T${hh}${mi}${ss}Z`;
    }
    const googleCalendarUrl =
      "https://calendar.google.com/calendar/render?action=TEMPLATE" +
      `&text=${encodeURIComponent(`Boda - ${event.honorees || "Invitación"}`)}` +
      `&dates=${toGoogleDate(startLocal)}/${toGoogleDate(endLocal)}` +
      `&details=${encodeURIComponent("Nos encantaría contar con tu presencia en este día especial.")}` +
      `&location=${encodeURIComponent(event.venue_address || event.venue_name || "")}`;
    function formatDate(dateStr) {
      if (!dateStr) return "14 de noviembre de 2026";
      const date = new Date(dateStr);
      const months = ["enero", "febrero", "marzo", "abril", "mayo", "junio", "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"];
      return `${date.getDate()} de ${months[date.getMonth()]} de ${date.getFullYear()}`;
    }
  %>

  <main class="page">
    <header class="hero">
      <img src="<%= heroImage %>" alt="Foto principal de la boda" />
      <div class="hero-content">
        <h1 class="hero-name"><%= event.hero_message || "Nos casamos" %></h1>
        <p class="hero-title"><%= event.honorees || "Nombre & Nombre" %></p>
      </div>
      <div class="hero-countdown" id="hero-countdown" data-date="<%= event.date || "" %>" data-time="<%= event.time || "" %>">
        <div class="hero-count-number" data-unit="days">--</div>
        <span class="hero-count-separator">:</span>
        <div class="hero-count-number" data-unit="hours">--</div>
        <span class="hero-count-separator">:</span>
        <div class="hero-count-number" data-unit="minutes">--</div>
        <span class="hero-count-separator">:</span>
        <div class="hero-count-number" data-unit="seconds">--</div>
      </div>
    </header>

    <section class="grid">
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifDestellos.webp" alt="Destellos" class="section-icon">
          <h2 class="section-title">¿Cuándo?</h2>
          <div class="section-divider"></div>
          <div class="info-list">
            <div><%= formatDate(event.date) %></div>
            <div><%= event.time || "19:30" %> hs</div>
          </div>
          <a class="calendar-btn" href="<%= googleCalendarUrl %>" target="_blank" rel="noopener noreferrer">
            Agregar al calendario
          </a>
        </div>
      </article>

      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifMapa.webp" alt="Mapa" class="section-icon">
          <h2 class="section-title">¿Dónde?</h2>
          <div class="section-divider"></div>
          <div class="info-list">
            <div><strong>Lugar:</strong> <%= event.venue_name || "Lugar del evento" %></div>
            <div><strong>Dirección:</strong> <%= event.venue_address || "Dirección" %></div>
          </div>
        </div>
      </article>

      <% if (sections && sections.location) { %>
      <article class="section-card">
        <div class="section-inner">
          <h2 class="section-title">Cómo llegar</h2>
          <div class="section-divider"></div>
          <div class="map-wrap">
            <iframe
              title="Mapa del evento"
              src="https://www.google.com/maps?q=<%= mapsQuery %>&output=embed"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      </article>
      <% } %>

      <% if (sections && sections.dress_code) { %>
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifDiamante.webp" alt="Diamante" class="section-icon">
          <h2 class="section-title">Dress Code</h2>
          <div class="section-divider"></div>
          <div class="info-list">
            <div><strong><%= event.dress_code || "Elegante Sport" %></strong></div>
            <div><%= event.reserved_message || (event.reserved_color ? `El color ${event.reserved_color} se reserva a la novia` : "") %></div>
          </div>
        </div>
      </article>
      <% } %>

      <% if (sections && sections.gallery) { %>
      <article class="section-card">
        <div class="section-inner">
          <h2 class="section-title">Galería</h2>
          <div class="section-divider"></div>
          <div class="gallery-track">
            <% galleryImages.forEach(function(photo) { %>
              <div class="gallery-item" data-photo="<%= photo %>">
                <img src="<%= photo %>" alt="Foto de galería de la boda" />
              </div>
            <% }) %>
          </div>
        </div>
      </article>
      <% } %>

      <article class="section-card">
        <div class="section-inner" style="text-align: center; padding: 32px 24px;">
          <div style="border-top: 1px solid var(--line); margin-bottom: 20px;"></div>
          <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 400; font-size: 1.15rem; line-height: 1.7; margin: 0 0 20px; color: var(--ink); letter-spacing: 0.03em;">
            Como un jardín florece con el sol,<br/>
            nuestro amor crece cada día,<br/>
            y en este momento, florece para siempre
          </p>
          <div style="border-bottom: 1px solid var(--line);"></div>
        </div>
      </article>

      <% if (sections && sections.gifts) { %>
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifRegalo.webp" alt="Regalo" class="section-icon">
          <h2 class="section-title">Obsequio</h2>
          <div class="section-divider"></div>
          <p class="section-sub"><%= event.gift_message || "Tu presencia es el mejor regalo. Pero si querés hacernos un obsequio, podés contribuir a nuestra luna de miel:" %></p>
          <button type="button" class="gift-toggle" id="gift-toggle">
            Ver datos para regalo
          </button>
          <div class="gift-box" id="gift-box">
            <div><strong>Alias:</strong> <%= giftAlias %></div>
            <div><strong>CBU:</strong> <%= giftCbu %></div>
            <div><strong>Titular:</strong> <%= event.gift_holder || "Nombre del titular" %></div>
          </div>
        </div>
      </article>
      <% } %>

      <% if (sections && sections.gallery2) { %>
      <article class="section-card">
        <div class="section-inner">
          <div class="gallery-track">
            <% gallery2Images.forEach(function(photo) { %>
              <div class="gallery-item" data-photo="<%= photo %>">
                <img src="<%= photo %>" alt="Foto de galería de la boda" />
              </div>
            <% }) %>
          </div>
        </div>
      </article>
      <% } %>
    </section>

    <section class="rsvp-section" style="margin-top:16px;">
      <h2 class="section-title">Confirmar asistencia</h2>
      <div class="section-divider"></div>
      <p class="section-sub">Por favor completá este formulario para ayudarnos a organizar mejor.</p>
      <form action="/api/<%= event.slug %>/rsvp" method="post">
        <div class="rsvp-grid">
          <div class="rsvp-field full">
            <label for="contact_name">Nombre de quien confirma</label>
            <input type="text" id="contact_name" name="contact_name" required>
          </div>
          <div class="rsvp-field">
            <label for="people_count">¿Cuántas personas van?</label>
            <input type="number" id="people_count" name="people_count" min="1" value="1" required>
          </div>
          <div class="rsvp-field">
            <label for="status">Asistencia</label>
            <select id="status" name="status">
              <option value="confirmed">Asistiremos</option>
              <option value="declined">No podemos asistir</option>
            </select>
          </div>
          <div class="rsvp-field full">
            <label for="people_names">Nombre y apellido de todos los que te acompañan</label>
            <textarea id="people_names" name="people_names" placeholder="Ej: Juan Pérez, Ana Gómez, Sofía López"></textarea>
          </div>
          <div class="rsvp-field full">
            <label for="food_preferences">Preferencias de comida</label>
            <textarea id="food_preferences" name="food_preferences" placeholder="Aclaraciones sobre alergias, vegetarianos, etc."></textarea>
          </div>
          <% if (sections && sections.music) { %>
          <div class="rsvp-field full">
            <label for="song_suggestions">Sugerencias de canciones</label>
            <textarea id="song_suggestions" name="song_suggestions" placeholder="Temas que te gustaría escuchar en la fiesta"></textarea>
          </div>
          <% } %>
          <div class="rsvp-field full">
            <label for="comments">Comentarios adicionales</label>
            <textarea id="comments" name="comments"></textarea>
          </div>
        </div>
        <button type="submit" class="send-btn">Enviar confirmación</button>
      </form>
    </section>
  </main>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close" aria-label="Cerrar">×</button>
    <img src="" alt="Foto ampliada de la galería" id="lightbox-image" />
  </div>

  <script>
    (function() {
      const qs = new URLSearchParams(window.location.search);
      if (qs.get("rsvp") === "ok") {
        window.alert("Gracias por confirmar tu asistencia.");
        qs.delete("rsvp");
        const clean = window.location.pathname + (qs.toString() ? "?" + qs.toString() : "");
        window.history.replaceState({}, "", clean);
      }

      const el = document.getElementById("hero-countdown");
      if (el) {
        const dateStr = el.getAttribute("data-date");
        const timeStr = el.getAttribute("data-time") || "00:00";
        if (dateStr) {
          const target = new Date(dateStr + "T" + timeStr + ":00");
          function update() {
            const now = new Date();
            let diff = target.getTime() - now.getTime();
            if (diff < 0) diff = 0;
            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
            const minutes = Math.floor((diff / (1000 * 60)) % 60);
            const seconds = Math.floor((diff / 1000) % 60);
            const set = (unit, value) => {
              const node = el.querySelector('[data-unit="' + unit + '"]');
              if (node) node.textContent = String(value).padStart(2, "0");
            };
            set("days", days);
            set("hours", hours);
            set("minutes", minutes);
            set("seconds", seconds);
          }
          update();
          setInterval(update, 1000);
        }
      }

      const giftToggle = document.getElementById("gift-toggle");
      const giftBox = document.getElementById("gift-box");
      if (giftToggle && giftBox) {
        giftToggle.addEventListener("click", function() {
          giftBox.classList.toggle("visible");
          giftToggle.textContent = giftBox.classList.contains("visible")
            ? "Ocultar datos para regalo"
            : "Ver datos para regalo";
        });
      }

      const lightbox = document.getElementById("lightbox");
      const lightboxImage = document.getElementById("lightbox-image");
      const lightboxClose = document.getElementById("lightbox-close");
      document.querySelectorAll(".gallery-item").forEach(function(item) {
        item.addEventListener("click", function() {
          const photo = item.getAttribute("data-photo");
          if (!photo || !lightbox || !lightboxImage) return;
          lightboxImage.src = photo;
          lightbox.classList.add("visible");
        });
      });
      if (lightboxClose && lightbox) {
        lightboxClose.addEventListener("click", function() {
          lightbox.classList.remove("visible");
        });
        lightbox.addEventListener("click", function(e) {
          if (e.target === lightbox) lightbox.classList.remove("visible");
        });
      }
    })();
  </script>
</body>
</html>

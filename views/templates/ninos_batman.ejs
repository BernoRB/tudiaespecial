<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= event.honorees || "Mi Cumple" %> · Invitación</title>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Roboto+Condensed:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #0d0d0d;
      --card: #1a1a1a;
      --ink: #e0e0e0;
      --muted: #a0a0a0;
      --accent: #ffd700;
      --accent-soft: #2a2a2a;
      --line: rgba(255, 215, 0, 0.3);
      --shadow: 0 18px 45px rgba(255, 215, 0, 0.15);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Roboto Condensed", sans-serif;
      background:
        radial-gradient(circle at 10% 0%, rgba(255, 215, 0, 0.05) 0%, transparent 40%),
        radial-gradient(circle at 100% 30%, rgba(255, 215, 0, 0.03) 0%, transparent 40%),
        var(--bg);
      color: var(--ink);
    }
    .page {
      width: 100%;
      max-width: 1120px;
      margin: 0 auto;
      padding: 18px 16px 60px;
      text-align: center;
    }
    .hero {
      position: relative;
      border-radius: 12px;
      overflow: hidden;
      min-height: 90vh;
      box-shadow: var(--shadow);
      margin-bottom: 24px;
      background: #000;
    }
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to top, rgba(0, 0, 0, 0.9), rgba(0, 0, 0, 0.3) 40%, rgba(0, 0, 0, 0.5));
      z-index: 1;
    }
    .hero::after {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, transparent 0%, rgba(0, 0, 0, 0.8) 100%);
      z-index: 2;
    }
    .hero img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      position: absolute;
      inset: 0;
    }
    .hero-content {
      position: relative;
      z-index: 3;
      color: #fff;
      min-height: 90vh;
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 12px;
      text-align: center;
    }
    .hero-kicker {
      font-family: "Oswald", sans-serif;
      font-weight: 600;
      font-size: 0.85rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      opacity: 0.95;
      color: var(--accent);
    }
    .hero-name {
      font-family: "Oswald", sans-serif;
      font-weight: 700;
      font-size: clamp(3rem, 12vw, 5rem);
      margin: 0;
      line-height: 1;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .hero-title {
      font-family: "Roboto Condensed", sans-serif;
      font-weight: 600;
      font-size: clamp(2rem, 8vw, 3.5rem);
      margin: 0;
      opacity: 0.95;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .hero-countdown {
      position: absolute;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 4;
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 6px;
      text-align: center;
    }
    .hero-count-number {
      font-family: "Oswald", sans-serif;
      font-weight: 700;
      font-size: 2rem;
      color: var(--accent);
      line-height: 1;
    }
    .hero-count-separator {
      font-family: "Oswald", sans-serif;
      font-weight: 700;
      font-size: 2rem;
      color: var(--accent);
      line-height: 1;
      opacity: 0.5;
    }

    .grid {
      display: grid;
      gap: 24px;
    }
    .section-card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 12px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .section-inner {
      padding: 40px 28px;
    }
    .section-title {
      font-family: "Oswald", sans-serif;
      font-weight: 700;
      font-size: 1.8rem;
      margin: 0 0 14px;
      color: var(--ink);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .section-sub {
      margin: 0 0 16px;
      color: var(--muted);
      font-size: 1.1rem;
      line-height: 1.6;
    }
    .section-divider {
      width: 100px;
      height: 3px;
      background: var(--accent);
      margin: 0 auto 20px auto;
      border-radius: 2px;
    }

    .info-list {
      display: grid;
      gap: 14px;
      margin-top: 14px;
      color: var(--muted);
      font-size: 1.15rem;
      line-height: 1.65;
      text-align: center;
    }
    .calendar-btn {
      margin-top: 12px;
      border: none;
      background: linear-gradient(90deg, #ffd700, #ffaa00);
      color: #0d0d0d;
      border-radius: 6px;
      padding: 12px 20px;
      font-size: 0.85rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      font-family: "Oswald", sans-serif;
      font-weight: 600;
    }

    .map-wrap {
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid var(--line);
      min-height: 250px;
      background: #111;
    }
    .map-wrap iframe {
      width: 100%;
      height: 250px;
      border: 0;
      display: block;
    }

    .gallery-track {
      display: flex;
      overflow-x: auto;
      gap: 12px;
      padding: 4px 4px 8px;
      scroll-snap-type: x mandatory;
    }
    .gallery-item {
      flex: 0 0 72%;
      border-radius: 10px;
      overflow: hidden;
      border: 3px solid var(--accent);
      box-shadow: 0 12px 32px rgba(255, 215, 0, 0.25);
      cursor: pointer;
      scroll-snap-align: start;
      background: #111;
      aspect-ratio: 4/5;
    }
    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .rsvp-section {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 12px;
      box-shadow: var(--shadow);
      padding: 32px 28px 36px;
    }
    .rsvp-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .rsvp-field label {
      display: block;
      margin-bottom: 6px;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
      font-family: "Oswald", sans-serif;
      font-weight: 600;
    }
    .rsvp-field input,
    .rsvp-field select,
    .rsvp-field textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 12px 16px;
      font: inherit;
      font-size: 1rem;
      color: var(--ink);
      background: #111;
      font-family: "Roboto Condensed", sans-serif;
    }
    .rsvp-field textarea {
      min-height: 72px;
      resize: vertical;
    }
    .full { grid-column: 1 / -1; }
    .send-btn {
      margin-top: 20px;
      width: 100%;
      border: none;
      background: linear-gradient(90deg, #ffd700, #ffaa00);
      color: #0d0d0d;
      border-radius: 6px;
      padding: 16px;
      font-size: 0.9rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      cursor: pointer;
      font-weight: 700;
      font-family: "Oswald", sans-serif;
    }

    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(13, 13, 13, 0.95);
      z-index: 9999;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .lightbox.visible { display: flex; }
    .lightbox img {
      max-width: 100%;
      max-height: 85vh;
      border-radius: 12px;
      box-shadow: 0 20px 60px rgba(255, 215, 0, 0.3);
    }
    .lightbox-close {
      position: absolute;
      top: 12px;
      right: 14px;
      border: 0;
      background: rgba(255, 215, 0, 0.2);
      color: #fff;
      width: 38px;
      height: 38px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 1.3rem;
    }

    @media (min-width: 900px) {
      .page { 
        padding: 30px 20px 80px; 
        max-width: 100%;
      }
      .hero {
        width: 75%;
        margin: 0 auto;
      }
      .hero, .hero-content { min-height: 85vh; }
      .hero-content { padding: 48px 48px; }
      .hero-countdown {
        bottom: 60px;
        gap: 24px;
      }
      .hero-count-number {
        font-size: 2.5rem;
      }
      .hero-count-separator {
        font-size: 2.5rem;
      }
      .grid {
        grid-template-columns: 1fr;
        gap: 48px;
      }
      .section-card {
        width: 75%;
        margin: 0 auto;
      }
      .section-inner { 
        padding: 52px 48px; 
        text-align: center;
      }
      .section-title {
        font-size: 2.2rem;
        margin-bottom: 16px;
      }
      .section-sub {
        font-size: 1.25rem;
        margin-bottom: 24px;
      }
      .section-divider {
        width: 120px;
        height: 4px;
        margin: 0 auto 32px auto;
      }
      .info-list {
        font-size: 1.25rem;
        gap: 16px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .gallery-track {
        justify-content: center;
      }
      .gallery-item { 
        flex-basis: 30%; 
        aspect-ratio: 4/5; 
      }
      .gallery-item img { height: 100%; }
      .map-wrap iframe { height: 380px; }
      .rsvp-section { 
        padding: 36px 32px 40px; 
        width: 75%;
        margin: 24px auto 0;
      }
      .rsvp-grid { 
        gap: 24px;
        text-align: center;
      }
      .rsvp-field label {
        font-size: 0.9rem;
        text-align: center;
      }
      .rsvp-field input,
      .rsvp-field select,
      .rsvp-field textarea {
        font-size: 1.1rem;
        padding: 14px 18px;
        text-align: center;
      }
      .send-btn {
        font-size: 1rem;
        padding: 18px;
      }
    }
  </style>
</head>
<body>
  <%
    const heroImage =
      event.hero_image ||
      "https://images.unsplash.com/photo-1531259683007-016a7b628fc3?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
    const galleryImages =
      event.gallery && Array.isArray(event.gallery) && event.gallery.length
        ? event.gallery
        : [
            "https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?q=80&w=1170&auto=format&fit=crop",
            "https://images.unsplash.com/photo-1519452575417-567c566f1318?q=80&w=1170&auto=format&fit=crop",
            "https://images.unsplash.com/photo-1544126562-807ade215a0b?q=80&w=1170&auto=format&fit=crop",
            "https://images.unsplash.com/photo-1470770841072-f978cf4d019e?q=80&w=1170&auto=format&fit=crop"
          ];
    const mapsQuery = encodeURIComponent(event.venue_address || event.venue_name || "Buenos Aires");
    const eventDateForCalendar = event.date || "2026-09-05";
    const eventTimeForCalendar = event.time || "16:00";
    const startLocal = new Date(`${eventDateForCalendar}T${eventTimeForCalendar}:00`);
    const endLocal = new Date(startLocal.getTime() + 4 * 60 * 60 * 1000);
    function toGoogleDate(d) {
      const yyyy = d.getUTCFullYear();
      const mm = String(d.getUTCMonth() + 1).padStart(2, "0");
      const dd = String(d.getUTCDate()).padStart(2, "0");
      const hh = String(d.getUTCHours()).padStart(2, "0");
      const mi = String(d.getUTCMinutes()).padStart(2, "0");
      const ss = String(d.getUTCSeconds()).padStart(2, "0");
      return `${yyyy}${mm}${dd}T${hh}${mi}${ss}Z`;
    }
    const googleCalendarUrl =
      "https://calendar.google.com/calendar/render?action=TEMPLATE" +
      `&text=${encodeURIComponent(`Cumpleaños - ${event.honorees || "Invitación"}`)}` +
      `&dates=${toGoogleDate(startLocal)}/${toGoogleDate(endLocal)}` +
      `&details=${encodeURIComponent("Te esperamos para celebrar juntos este día especial.")}` +
      `&location=${encodeURIComponent(event.venue_address || event.venue_name || "")}`;
    function formatDate(dateStr) {
      if (!dateStr) return "22 de octubre de 2026";
      const date = new Date(dateStr);
      const months = ["enero", "febrero", "marzo", "abril", "mayo", "junio", "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"];
      return `${date.getDate()} de ${months[date.getMonth()]} de ${date.getFullYear()}`;
    }
  %>

  <main class="page">
    <header class="hero">
      <img src="<%= heroImage %>" alt="Foto principal del evento" />
      <div class="hero-content">
        <div class="hero-kicker">INVITACIÓN · MI CUMPLE</div>
        <h1 class="hero-name">MI CUMPLE</h1>
        <p class="hero-title"><%= event.honorees || "Bruce" %></p>
      </div>
      <div class="hero-countdown" id="hero-countdown" data-date="<%= event.date || "" %>" data-time="<%= event.time || "" %>">
        <div class="hero-count-number" data-unit="days">--</div>
        <span class="hero-count-separator">:</span>
        <div class="hero-count-number" data-unit="hours">--</div>
        <span class="hero-count-separator">:</span>
        <div class="hero-count-number" data-unit="minutes">--</div>
        <span class="hero-count-separator">:</span>
        <div class="hero-count-number" data-unit="seconds">--</div>
      </div>
    </header>

    <section class="grid">
      <article class="section-card">
        <div class="section-inner">
          <h2 class="section-title">¿Cuándo?</h2>
          <div class="section-divider"></div>
          <div class="info-list">
            <div><%= formatDate(event.date) %></div>
            <div><%= event.time || "16:00" %> hs</div>
          </div>
          <a class="calendar-btn" href="<%= googleCalendarUrl %>" target="_blank" rel="noopener noreferrer">
            Agregar al calendario
          </a>
        </div>
      </article>

      <article class="section-card">
        <div class="section-inner">
          <h2 class="section-title">¿Dónde?</h2>
          <div class="section-divider"></div>
          <div class="info-list">
            <div><strong>Lugar:</strong> <%= event.venue_name || "Salón de fiestas" %></div>
            <div><strong>Dirección:</strong> <%= event.venue_address || "Dirección del evento" %></div>
          </div>
        </div>
      </article>

      <% const sections = event.sections_json ? JSON.parse(event.sections_json) : (event.sections || {}); %>
      <% if (sections && sections.location) { %>
      <article class="section-card">
        <div class="section-inner">
          <h2 class="section-title">Cómo llegar</h2>
          <div class="section-divider"></div>
          <div class="map-wrap">
            <iframe
              title="Mapa del evento"
              src="https://www.google.com/maps?q=<%= mapsQuery %>&output=embed"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      </article>
      <% } %>

      <% if (sections && sections.gallery) { %>
      <article class="section-card">
        <div class="section-inner">
          <h2 class="section-title">Galería</h2>
          <div class="section-divider"></div>
          <div class="gallery-track">
            <% galleryImages.forEach(function(photo) { %>
              <div class="gallery-item" data-photo="<%= photo %>">
                <img src="<%= photo %>" alt="Foto de galería del evento" />
              </div>
            <% }) %>
          </div>
        </div>
      </article>
      <% } %>

      <article class="section-card">
        <div class="section-inner" style="text-align: center; padding: 32px 24px;">
          <div style="border-top: 1px solid var(--line); margin-bottom: 20px;"></div>
          <p style="font-family: 'Roboto Condensed', sans-serif; font-weight: 500; font-size: 1.2rem; line-height: 1.7; margin: 0 0 20px; color: var(--ink); letter-spacing: 0.02em;">
            Un día de acción y aventura,<br/>
            donde cada momento es épico,<br/>
            y la diversión no tiene límites
          </p>
          <div style="border-bottom: 1px solid var(--line);"></div>
        </div>
      </article>
    </section>

    <section class="rsvp-section" style="margin-top:16px;">
      <h2 class="section-title">Confirmar asistencia</h2>
      <div class="section-divider"></div>
      <p class="section-sub">¡Quiero saber si vas a estar! Completá tus datos acá abajo.</p>
      <form action="/api/<%= event.slug %>/rsvp" method="post">
        <div class="rsvp-grid">
          <div class="rsvp-field full">
            <label for="contact_name">Nombre de quien confirma</label>
            <input type="text" id="contact_name" name="contact_name" required>
          </div>
          <div class="rsvp-field">
            <label for="people_count">¿Cuántos vienen?</label>
            <input type="number" id="people_count" name="people_count" min="1" value="1" required>
          </div>
          <div class="rsvp-field">
            <label for="status">Asistencia</label>
            <select id="status" name="status">
              <option value="confirmed">Voy / Vamos</option>
              <option value="declined">No puedo ir</option>
            </select>
          </div>
          <div class="rsvp-field full">
            <label for="people_names">Nombre y apellido de todos los que te acompañan</label>
            <textarea id="people_names" name="people_names" placeholder="Ej: Juan Pérez, Ana Gómez, Sofía López"></textarea>
          </div>
        </div>
        <button type="submit" class="send-btn">Enviar confirmación</button>
      </form>
    </section>
  </main>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close" aria-label="Cerrar">×</button>
    <img src="" alt="Foto ampliada de la galería" id="lightbox-image" />
  </div>

  <script>
    (function() {
      const qs = new URLSearchParams(window.location.search);
      if (qs.get("rsvp") === "ok") {
        window.alert("Gracias por confirmar tu asistencia.");
        qs.delete("rsvp");
        const clean = window.location.pathname + (qs.toString() ? "?" + qs.toString() : "");
        window.history.replaceState({}, "", clean);
      }

      const el = document.getElementById("hero-countdown");
      if (el) {
        const dateStr = el.getAttribute("data-date");
        const timeStr = el.getAttribute("data-time") || "00:00";
        if (dateStr) {
          const target = new Date(dateStr + "T" + timeStr + ":00");
          function update() {
            const now = new Date();
            let diff = target.getTime() - now.getTime();
            if (diff < 0) diff = 0;
            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
            const minutes = Math.floor((diff / (1000 * 60)) % 60);
            const seconds = Math.floor((diff / 1000) % 60);
            const set = (unit, value) => {
              const node = el.querySelector('[data-unit="' + unit + '"]');
              if (node) node.textContent = String(value).padStart(2, "0");
            };
            set("days", days);
            set("hours", hours);
            set("minutes", minutes);
            set("seconds", seconds);
          }
          update();
          setInterval(update, 1000);
        }
      }

      const lightbox = document.getElementById("lightbox");
      const lightboxImage = document.getElementById("lightbox-image");
      const lightboxClose = document.getElementById("lightbox-close");
      document.querySelectorAll(".gallery-item").forEach(function(item) {
        item.addEventListener("click", function() {
          const photo = item.getAttribute("data-photo");
          if (!photo || !lightbox || !lightboxImage) return;
          lightboxImage.src = photo;
          lightbox.classList.add("visible");
        });
      });
      if (lightboxClose && lightbox) {
        lightboxClose.addEventListener("click", function() {
          lightbox.classList.remove("visible");
        });
        lightbox.addEventListener("click", function(e) {
          if (e.target === lightbox) lightbox.classList.remove("visible");
        });
      }
    })();
  </script>
</body>
</html>

        ? event.gallery
        : [
            "https://scontent-bcn1-1.xx.fbcdn.net/v/t39.30808-6/666751575_1510754931055442_8289332625988079312_n.jpg?_nc_cat=110&ccb=1-7&_nc_sid=dd6889&_nc_ohc=MKgtETlTKFYQ7kNvwGu6Thg&_nc_oc=AdqlmdtNXgD4g-3oNIf-Uno9PGEuKo0PufNAOm77mcgy_HicLSQdB6sz0lgaq21OmOg_lU_Yk9nobegGazLyyEdr&_nc_zt=23&_nc_ht=scontent-bcn1-1.xx&_nc_gid=mU99sHKiFof2WG7oDlvMow&_nc_ss=7a3a8&oh=00_Af1SncMWWbSxizp_QTsC2cOZdIc5E8nM9csQge6ry3zWAg&oe=69E67BD7",
            "https://scontent-bcn1-1.xx.fbcdn.net/v/t39.30808-6/663243355_1510754894388779_8594600763049735765_n.jpg?_nc_cat=104&ccb=1-7&_nc_sid=dd6889&_nc_ohc=xnynUrosxmoQ7kNvwF2IZWW&_nc_oc=AdpVxW2Ovi1mcdwiMKpQBlHpzKAH8I976ucWvcGM7zo2tb7ILoox1lsTCrp7zIuDRsQL2y_lWhucOIX6Vdsqak0G&_nc_zt=23&_nc_ht=scontent-bcn1-1.xx&_nc_gid=TWIspT4FTBovjwomJbamZQ&_nc_ss=7a3a8&oh=00_Af2KPNcoRxtKTYpRD1C9XG3OH52yoP7gj9B7yeQcKWbqfA&oe=69E6A754",
            "https://scontent-bcn1-1.xx.fbcdn.net/v/t39.30808-6/664937367_1510754897722112_5354038272186325419_n.jpg?_nc_cat=103&ccb=1-7&_nc_sid=dd6889&_nc_ohc=TpoiZ8Aqcx8Q7kNvwE2v9WS&_nc_oc=AdrwZ_E7eTG9gMyX5FB8RdXrgVyVGWe83Qm40bC6-qo6wOVpKmh_x0ljPoyrut1oM29EILE1FKgM53aMeDaVm02j&_nc_zt=23&_nc_ht=scontent-bcn1-1.xx&_nc_gid=rwn9NRrFO3JIKxMgrkcnjQ&_nc_ss=7a3a8&oh=00_Af1S8bcrDiSyFTNq1DOUZ0O-6V2MM77gjRz6_705WPtk2A&oe=69E6A35B",
            "https://scontent-bcn1-1.xx.fbcdn.net/v/t39.30808-6/668582614_1510755014388767_2931924222257879731_n.jpg?_nc_cat=100&ccb=1-7&_nc_sid=dd6889&_nc_ohc=38ihzQFjUtcQ7kNvwHB0CL3&_nc_oc=Adq4WKkTpIkVwRw9CY3FgbAd_356gKXIh-l_aPnIbUaYKJ-hUj8vfS6V-0UUDUsRMgcveZIFeyGGtnvVpyQuyYS6&_nc_zt=23&_nc_ht=scontent-bcn1-1.xx&_nc_gid=1BuW2pQUQZqBqO8ln8ogAA&_nc_ss=7a3a8&oh=00_Af35BGY0A0PkoLAzDUulFy47GSQ6EuIGiTSwcuMILp5cQg&oe=69E6789F"
          ];
    const gallery2Images =
      event.gallery2 && Array.isArray(event.gallery2) && event.gallery2.length
        ? event.gallery2
        : [
            "https://scontent-bcn1-1.xx.fbcdn.net/v/t39.30808-6/666207467_1510754737722128_4364136248362386856_n.jpg?_nc_cat=106&ccb=1-7&_nc_sid=dd6889&_nc_ohc=Su9gSd0zlt0Q7kNvwFPi6y1&_nc_oc=AdprmuuiiqdEp6lj6UcUbYfd9uFh6T7Bpds51De3FFVjIcpioV4HLVd4hSgFhFsTUbZDPP85-lO-k3CD3mCM-WdR&_nc_zt=23&_nc_ht=scontent-bcn1-1.xx&_nc_gid=dkopQPpMces-aiJIgdmC3Q&_nc_ss=7a3a8&oh=00_Af38ctcrTJboo8VJazeC5oIg5XDuwFyU7GCjjLiIp5-0Tw&oe=69E69FD8",
            "https://scontent-bcn1-1.xx.fbcdn.net/v/t39.30808-6/667037047_1510755087722093_487563248076689037_n.jpg?_nc_cat=101&ccb=1-7&_nc_sid=dd6889&_nc_ohc=WKou9OwbAkcQ7kNvwE_X4xm&_nc_oc=Adp051RNPvV1cduVSaUXEOF5DUvkbqjntQOhIpx7GspTAEw6pVA14IUuL7oIbgd9edM6MDaepQbKi3SL5E8ayvkQ&_nc_zt=23&_nc_ht=scontent-bcn1-1.xx&_nc_gid=jY2ywYgVm7zo7zkb-Hw6OA&_nc_ss=7a3a8&oh=00_Af0DOl225kg0uM2GmLch3LbZ1WkIv4U7qz9y6_JGfIx5sw&oe=69E6A539",
            "https://scontent-bcn1-1.xx.fbcdn.net/v/t39.30808-6/667612218_1510754814388787_7822848700335048913_n.jpg?_nc_cat=108&ccb=1-7&_nc_sid=dd6889&_nc_ohc=7gvWmJvoCd4Q7kNvwGNFrpu&_nc_oc=Adp9TQNDZe2nmrfxdWETZbeFJvLZRguMM_S4dqNpKO5z88ukCTxB1ZE6LGpz79gjd4vEWFkFwV1spArAxI3X4-DD&_nc_zt=23&_nc_ht=scontent-bcn1-1.xx&_nc_gid=kXJpM4GrYdBcvdTE1iPY5w&_nc_ss=7a3a8&oh=00_Af1iTQgDM7MnOs2LKPsxxggxB99mDRrbYK9bOh3yD57IvA&oe=69E67DD6",
            "https://scontent-bcn1-1.xx.fbcdn.net/v/t39.30808-6/667531250_1510754994388769_6875189510125194386_n.jpg?_nc_cat=101&ccb=1-7&_nc_sid=dd6889&_nc_ohc=5-y1K1GLa5QQ7kNvwF0fwTR&_nc_oc=Adp3PrW4bo24sK6IRhho-1qDYAhMInka0vhWisiUWajvrC_c0__ZJVm0jmofTlpuw3eBwJbbhW2lrsViD04gVCHo&_nc_zt=23&_nc_ht=scontent-bcn1-1.xx&_nc_gid=xt-lfVwss3e9dVV9lQAI0w&_nc_ss=7a3a8&oh=00_Af1b1b-VmtxXeeu7ambxeCVg7yu3FueWvHChF8r3igW3MQ&oe=69E6A888"
          ];
    const mapsQuery = encodeURIComponent(event.venue_address || event.venue_name || "Buenos Aires");
    const giftCbu = event.gift_cbu || "0000000000000000000000";
    const giftAlias = event.gift_alias || "mis15.alias";
    const eventDateForCalendar = event.date || "2026-09-05";
    const eventTimeForCalendar = event.time || "21:00";
    const startLocal = new Date(`${eventDateForCalendar}T${eventTimeForCalendar}:00`);
    const endLocal = new Date(startLocal.getTime() + 4 * 60 * 60 * 1000);
    function toGoogleDate(d) {
      const yyyy = d.getUTCFullYear();
      const mm = String(d.getUTCMonth() + 1).padStart(2, "0");
      const dd = String(d.getUTCDate()).padStart(2, "0");
      const hh = String(d.getUTCHours()).padStart(2, "0");
      const mi = String(d.getUTCMinutes()).padStart(2, "0");
      const ss = String(d.getUTCSeconds()).padStart(2, "0");
      return `${yyyy}${mm}${dd}T${hh}${mi}${ss}Z`;
    }
    const googleCalendarUrl =
      "https://calendar.google.com/calendar/render?action=TEMPLATE" +
      `&text=${encodeURIComponent(`Mis 15 - ${event.honorees || "Invitación"}`)}` +
      `&dates=${toGoogleDate(startLocal)}/${toGoogleDate(endLocal)}` +
      `&details=${encodeURIComponent("Te esperamos para celebrar juntos este día especial.")}` +
      `&location=${encodeURIComponent(event.venue_address || event.venue_name || "")}`;
    function formatDate(dateStr) {
      if (!dateStr) return "22 de octubre de 2026";
      const date = new Date(dateStr);
      const months = ["enero", "febrero", "marzo", "abril", "mayo", "junio", "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"];
      return `${date.getDate()} de ${months[date.getMonth()]} de ${date.getFullYear()}`;
    }
  %>

  <main class="page">
    <header class="hero">
      <img src="<%= heroImage %>" alt="Foto principal del evento" />
      <div class="hero-content">
        <div class="hero-kicker">INVITACIÓN · MIS QUINCE</div>
        <h1 class="hero-name">MIS 15</h1>
        <p class="hero-title"><%= event.honorees || "Delfina" %></p>
      </div>
      <div class="hero-countdown" id="hero-countdown" data-date="<%= event.date || "" %>" data-time="<%= event.time || "" %>">
        <div class="hero-count-number" data-unit="days">--</div>
        <span class="hero-count-separator">:</span>
        <div class="hero-count-number" data-unit="hours">--</div>
        <span class="hero-count-separator">:</span>
        <div class="hero-count-number" data-unit="minutes">--</div>
        <span class="hero-count-separator">:</span>
        <div class="hero-count-number" data-unit="seconds">--</div>
      </div>
    </header>

    <section class="grid">
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifDestellos.webp" alt="Destellos" class="section-icon">
          <h2 class="section-title">¿Cuándo?</h2>
          <div class="section-divider"></div>
          <div class="info-list">
            <div><%= formatDate(event.date) %></div>
            <div><%= event.time || "21:00" %> hs</div>
          </div>
          <a class="calendar-btn" href="<%= googleCalendarUrl %>" target="_blank" rel="noopener noreferrer">
            Agregar al calendario
          </a>
        </div>
      </article>

      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifMapa.webp" alt="Mapa" class="section-icon">
          <h2 class="section-title">¿Dónde?</h2>
          <div class="section-divider"></div>
          <div class="info-list">
            <div><strong>Lugar:</strong> <%= event.venue_name || "Salón de fiestas" %></div>
            <div><strong>Dirección:</strong> <%= event.venue_address || "Dirección del evento" %></div>
          </div>
        </div>
      </article>

      <% if (sections && sections.location) { %>
      <article class="section-card">
        <div class="section-inner">
          <h2 class="section-title">Cómo llegar</h2>
          <div class="section-divider"></div>
          <div class="map-wrap">
            <iframe
              title="Mapa del evento"
              src="https://www.google.com/maps?q=<%= mapsQuery %>&output=embed"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      </article>
      <% } %>

      <% if (sections && sections.dress_code) { %>
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifDiamante.webp" alt="Diamante" class="section-icon">
          <h2 class="section-title">Dress Code</h2>
          <div class="section-divider"></div>
          <div class="info-list">
            <div><strong><%= event.dress_code || "Elegante Sport" %></strong></div>
            <div><%= event.reserved_message || (event.reserved_color ? `El color ${event.reserved_color} se reserva a la cumpleañera` : "") %></div>
          </div>
        </div>
      </article>
      <% } %>

      <% if (sections && sections.gallery) { %>
      <article class="section-card">
        <div class="section-inner">
          <h2 class="section-title">Galería</h2>
          <div class="section-divider"></div>
          <div class="gallery-track">
            <% galleryImages.forEach(function(photo) { %>
              <div class="gallery-item" data-photo="<%= photo %>">
                <img src="<%= photo %>" alt="Foto de galería del evento" />
              </div>
            <% }) %>
          </div>
        </div>
      </article>
      <% } %>

      <article class="section-card">
        <div class="section-inner" style="text-align: center; padding: 32px 24px;">
          <div style="border-top: 1px solid var(--line); margin-bottom: 20px;"></div>
          <p style="font-family: 'Rajdhani', sans-serif; font-weight: 500; font-size: 1.15rem; line-height: 1.7; margin: 0 0 20px; color: var(--ink); letter-spacing: 0.03em;">
            Una noche llena de luz,<br/>
            donde cada momento brilla,<br/>
            y los recuerdos se vuelven eternos
          </p>
          <div style="border-bottom: 1px solid var(--line);"></div>
        </div>
      </article>

      <% if (sections && sections.gifts) { %>
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifRegalo.webp" alt="Regalo" class="section-icon">
          <h2 class="section-title">Regalo</h2>
          <div class="section-divider"></div>
          <p class="section-sub"><%= event.gift_message || "Con tu presencia alcanza, pero si deseas hacerme un regalo será recibido con mucho amor. También podés hacerlo a la siguiente cuenta." %></p>
          <button type="button" class="gift-toggle" id="gift-toggle">
            Ver datos para regalo
          </button>
          <div class="gift-box" id="gift-box">
            <div><strong>Alias:</strong> <%= giftAlias %></div>
            <div><strong>CBU:</strong> <%= giftCbu %></div>
            <div><strong>Titular:</strong> <%= event.gift_holder || "Nombre del titular" %></div>
          </div>
        </div>
      </article>
      <% } %>

      <% if (sections && sections.gallery2) { %>
      <article class="section-card">
        <div class="section-inner">
          <div class="gallery-track">
            <% gallery2Images.forEach(function(photo) { %>
              <div class="gallery-item" data-photo="<%= photo %>">
                <img src="<%= photo %>" alt="Foto de galería del evento" />
              </div>
            <% }) %>
          </div>
        </div>
      </article>
      <% } %>
    </section>

    <section class="rsvp-section" style="margin-top:16px;">
      <h2 class="section-title">Confirmar asistencia</h2>
      <div class="section-divider"></div>
      <p class="section-sub">¡Quiero saber si vas a estar! Completá tus datos acá abajo.</p>
      <form action="/api/<%= event.slug %>/rsvp" method="post">
        <div class="rsvp-grid">
          <div class="rsvp-field full">
            <label for="contact_name">Nombre de quien confirma</label>
            <input type="text" id="contact_name" name="contact_name" required>
          </div>
          <div class="rsvp-field">
            <label for="people_count">¿Cuántos vienen?</label>
            <input type="number" id="people_count" name="people_count" min="1" value="1" required>
          </div>
          <div class="rsvp-field">
            <label for="status">Asistencia</label>
            <select id="status" name="status">
              <option value="confirmed">Voy / Vamos</option>
              <option value="declined">No puedo ir</option>
            </select>
          </div>
          <div class="rsvp-field full">
            <label for="people_names">Nombre y apellido de todos los que te acompañan</label>
            <textarea id="people_names" name="people_names" placeholder="Ej: Juan Pérez, Ana Gómez, Sofía López"></textarea>
          </div>
          <div class="rsvp-field full">
            <label for="food_preferences">Preferencias de comida</label>
            <textarea id="food_preferences" name="food_preferences" placeholder="Aclaraciones sobre comida"></textarea>
          </div>
          <% if (sections && sections.music) { %>
            <div class="rsvp-field full">
              <label for="song_suggestions">Temas que no pueden faltar</label>
              <textarea id="song_suggestions" name="song_suggestions" placeholder="Decime qué canciones querés bailar"></textarea>
            </div>
          <% } %>
          <div class="rsvp-field full">
            <label for="comments">Mensajito para mí</label>
            <textarea id="comments" name="comments"></textarea>
          </div>
        </div>
        <button type="submit" class="send-btn">Enviar confirmación</button>
      </form>
    </section>
  </main>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close" aria-label="Cerrar">×</button>
    <img src="" alt="Foto ampliada de la galería" id="lightbox-image" />
  </div>

  <script>
    (function() {
      const qs = new URLSearchParams(window.location.search);
      if (qs.get("rsvp") === "ok") {
        window.alert("Gracias por confirmar tu asistencia.");
        qs.delete("rsvp");
        const clean = window.location.pathname + (qs.toString() ? "?" + qs.toString() : "");
        window.history.replaceState({}, "", clean);
      }

      const el = document.getElementById("hero-countdown");
      if (el) {
        const dateStr = el.getAttribute("data-date");
        const timeStr = el.getAttribute("data-time") || "00:00";
        if (dateStr) {
          const target = new Date(dateStr + "T" + timeStr + ":00");
          function update() {
            const now = new Date();
            let diff = target.getTime() - now.getTime();
            if (diff < 0) diff = 0;
            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
            const minutes = Math.floor((diff / (1000 * 60)) % 60);
            const seconds = Math.floor((diff / 1000) % 60);
            const set = (unit, value) => {
              const node = el.querySelector('[data-unit="' + unit + '"]');
              if (node) node.textContent = String(value).padStart(2, "0");
            };
            set("days", days);
            set("hours", hours);
            set("minutes", minutes);
            set("seconds", seconds);
          }
          update();
          setInterval(update, 1000);
        }
      }

      const giftToggle = document.getElementById("gift-toggle");
      const giftBox = document.getElementById("gift-box");
      if (giftToggle && giftBox) {
        giftToggle.addEventListener("click", function() {
          giftBox.classList.toggle("visible");
          giftToggle.textContent = giftBox.classList.contains("visible")
            ? "Ocultar datos para regalo"
            : "Ver datos para regalo";
        });
      }

      const lightbox = document.getElementById("lightbox");
      const lightboxImage = document.getElementById("lightbox-image");
      const lightboxClose = document.getElementById("lightbox-close");
      document.querySelectorAll(".gallery-item").forEach(function(item) {
        item.addEventListener("click", function() {
          const photo = item.getAttribute("data-photo");
          if (!photo || !lightbox || !lightboxImage) return;
          lightboxImage.src = photo;
          lightbox.classList.add("visible");
        });
      });
      if (lightboxClose && lightbox) {
        lightboxClose.addEventListener("click", function() {
          lightbox.classList.remove("visible");
        });
        lightbox.addEventListener("click", function(e) {
          if (e.target === lightbox) lightbox.classList.remove("visible");
        });
      }
    })();
  </script>
</body>
</html>

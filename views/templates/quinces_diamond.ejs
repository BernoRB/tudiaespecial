<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= event.honorees || "Mis 15" %> · Invitación</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <style>
    :root {
      --bg: #0a0a0a;
      --card: #1a1a1a;
      --ink: #ffffff;
      --muted: #a0a0a0;
      --accent: #00d4ff;
      --accent-soft: rgba(0, 212, 255, 0.1);
      --line: rgba(0, 212, 255, 0.3);
      --shadow: 0 18px 45px rgba(0, 212, 255, 0.15);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Rajdhani", sans-serif;
      background:
        radial-gradient(circle at 10% 0%, rgba(0, 212, 255, 0.1) 0%, transparent 40%),
        radial-gradient(circle at 100% 30%, rgba(0, 212, 255, 0.08) 0%, transparent 40%),
        var(--bg);
      color: var(--ink);
    }
    .page {
      width: 100%;
      max-width: 1120px;
      margin: 0 auto;
      padding: 18px 16px 60px;
      text-align: center;
    }
    .hero {
      position: relative;
      border-radius: 16px;
      overflow: hidden;
      min-height: 90vh;
      box-shadow: var(--shadow);
      margin-bottom: 24px;
      background: #000;
    }
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to top, rgba(0, 0, 0, 0.9), rgba(0, 0, 0, 0.3) 40%, rgba(0, 0, 0, 0.5));
      z-index: 1;
    }
    .hero img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      position: absolute;
      inset: 0;
    }
    .hero-content {
      position: relative;
      z-index: 2;
      color: #fff;
      min-height: 90vh;
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 8px;
      text-align: center;
    }
    .hero-kicker {
      font-family: "Orbitron", sans-serif;
      font-size: 0.85rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      opacity: 0.95;
      color: var(--accent);
    }
    .hero-name {
      font-family: "Orbitron", sans-serif;
      font-weight: 700;
      font-size: clamp(3rem, 12vw, 5rem);
      margin: 0;
      line-height: 1;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .hero-title {
      font-family: "Rajdhani", sans-serif;
      font-weight: 600;
      font-size: clamp(2rem, 8vw, 3.5rem);
      margin: 0;
      opacity: 0.95;
      letter-spacing: 0.1em;
    }

    .hero-countdown {
      position: absolute;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 3;
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 4px;
      text-align: center;
    }
    .hero-count-number {
      font-family: "Orbitron", sans-serif;
      font-weight: 700;
      font-size: 2rem;
      color: var(--accent);
      line-height: 1;
    }
    .hero-count-separator {
      font-family: "Orbitron", sans-serif;
      font-weight: 700;
      font-size: 2rem;
      color: var(--accent);
      line-height: 1;
      opacity: 0.5;
    }

    .grid {
      display: grid;
      gap: 24px;
    }
    .section-card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 12px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .section-inner {
      padding: 40px 28px;
    }
    .section-title {
      font-family: "Orbitron", sans-serif;
      font-weight: 600;
      font-size: 1.65rem;
      margin: 0 0 14px;
      color: var(--ink);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .section-sub {
      margin: 0 0 16px;
      color: var(--muted);
      font-size: 1.08rem;
      line-height: 1.6;
    }
    .section-divider {
      width: 80px;
      height: 1px;
      background: var(--accent);
      margin: 0 auto 20px auto;
      border-radius: 0.5px;
    }
    .section-icon {
      width: 72px;
      height: 72px;
      margin: 0 auto 22px auto;
      object-fit: contain;
      display: block;
      background: #000;
      border-radius: 50%;
      padding: 8px;
      border: 2px solid var(--accent);
    }

    .info-list {
      display: grid;
      gap: 14px;
      margin-top: 14px;
      color: var(--muted);
      font-size: 1.1rem;
      line-height: 1.65;
      text-align: center;
    }
    .calendar-btn {
      margin-top: 12px;
      border: none;
      background: linear-gradient(90deg, #00d4ff, #00a8cc);
      color: #000;
      border-radius: 6px;
      padding: 11px 16px;
      font-size: 0.78rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      font-family: "Orbitron", sans-serif;
      font-weight: 600;
    }

    .map-wrap {
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid var(--line);
      min-height: 250px;
      background: #111;
    }
    .map-wrap iframe {
      width: 100%;
      height: 250px;
      border: 0;
      display: block;
    }

    .gallery-track {
      display: flex;
      overflow-x: auto;
      gap: 10px;
      padding: 2px 2px 4px;
      scroll-snap-type: x mandatory;
    }
    .gallery-item {
      flex: 0 0 72%;
      border-radius: 8px;
      overflow: hidden;
      border: 3px solid var(--accent);
      box-shadow: 0 12px 32px rgba(0, 212, 255, 0.25);
      cursor: pointer;
      scroll-snap-align: start;
      background: #111;
      aspect-ratio: 4/5;
    }
    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .gift-toggle {
      width: 100%;
      border: 1px solid var(--line);
      background: var(--accent-soft);
      border-radius: 8px;
      color: var(--accent);
      padding: 14px 18px;
      font-weight: 600;
      cursor: pointer;
      text-align: center;
      font-family: "Orbitron", sans-serif;
      letter-spacing: 0.05em;
    }
    .gift-box {
      display: none;
      margin-top: 12px;
      padding: 16px;
      border: 1px solid var(--line);
      border-radius: 8px;
      color: var(--muted);
      font-size: 0.95rem;
      background: #111;
      line-height: 1.6;
      text-align: center;
    }
    .gift-box.visible { display: block; }

    .rsvp-section {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 12px;
      box-shadow: var(--shadow);
      padding: 28px 24px 32px;
    }
    .rsvp-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .rsvp-field label {
      display: block;
      margin-bottom: 5px;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
    }
    .rsvp-field input,
    .rsvp-field select,
    .rsvp-field textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 10px 12px;
      font: inherit;
      font-size: 0.92rem;
      color: var(--ink);
      background: #111;
    }
    .rsvp-field textarea {
      min-height: 72px;
      resize: vertical;
    }
    .full { grid-column: 1 / -1; }
    .send-btn {
      margin-top: 16px;
      width: 100%;
      border: none;
      background: linear-gradient(90deg, #00d4ff, #00a8cc);
      color: #000;
      border-radius: 6px;
      padding: 14px;
      font-size: 0.82rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      cursor: pointer;
      font-weight: 700;
      font-family: "Orbitron", sans-serif;
    }

    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.95);
      z-index: 9999;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .lightbox.visible { display: flex; }
    .lightbox img {
      max-width: 100%;
      max-height: 85vh;
      border-radius: 12px;
      box-shadow: 0 20px 60px rgba(0, 212, 255, 0.3);
    }
    .lightbox-close {
      position: absolute;
      top: 12px;
      right: 14px;
      border: 0;
      background: rgba(0, 212, 255, 0.2);
      color: #fff;
      width: 38px;
      height: 38px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 1.3rem;
    }

    @media (min-width: 900px) {
      .page { 
        padding: 30px 20px 80px; 
        max-width: 100%;
      }
      .hero {
        width: 75%;
        margin: 0 auto;
      }
      .hero, .hero-content { min-height: 85vh; }
      .hero-content { padding: 48px 48px; }
      .hero-countdown {
        bottom: 60px;
        gap: 24px;
      }
      .hero-count-number {
        font-size: 2.5rem;
      }
      .hero-count-separator {
        font-size: 2.5rem;
      }
      .grid {
        grid-template-columns: 1fr;
        gap: 48px;
      }
      .section-card {
        width: 75%;
        margin: 0 auto;
      }
      .section-inner { 
        padding: 52px 48px; 
        text-align: center;
      }
      .section-title {
        font-size: 2rem;
        margin-bottom: 16px;
      }
      .section-sub {
        font-size: 1.2rem;
        margin-bottom: 24px;
      }
      .section-divider {
        width: 100px;
        height: 2px;
        margin: 0 auto 32px auto;
      }
      .info-list {
        font-size: 1.2rem;
        gap: 16px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .gallery-track {
        justify-content: center;
      }
      .gallery-item { 
        flex-basis: 30%; 
        aspect-ratio: 4/5; 
      }
      .gallery-item img { height: 100%; }
      .map-wrap iframe { height: 380px; }
      .rsvp-section { 
        padding: 32px 28px 36px; 
        width: 75%;
        margin: 24px auto 0;
      }
      .rsvp-grid { 
        gap: 24px;
        text-align: center;
      }
      .rsvp-field label {
        font-size: 0.85rem;
        text-align: center;
      }
      .rsvp-field input,
      .rsvp-field select,
      .rsvp-field textarea {
        font-size: 1.05rem;
        padding: 14px 16px;
        text-align: center;
      }
      .send-btn {
        font-size: 0.9rem;
        padding: 16px;
      }
    }
  </style>
</head>
<body>
  <%
    const heroImage =
      event.hero_image ||

<!DOCTYPE html>
<html lang="es-AR">
<head>
<%- include('../partials/meta-tags', {
  title: (event.honorees || "Isabella") + " - Mis Quince",
  description: (event.honorees || "Isabella") + " - Te invito a celebrar mis quince años",
  keywords: "invitación digital quinces, " + (event.honorees || "") + ", " + (event.venue_name || "") + ", Argentina",
  url: "https://tudiaespecial.com" + req.originalUrl,
  type: "article"
}) %>

<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Orbitron:wght@400;500;600;700&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="icon" type="image/png" href="/images/favicon.png">
<style>
    :root {
      --bg: #0a0a0a;
      --card: #1a1a1a;
      --ink: #ffffff;
      --muted: #c8c8c8;
      --accent: #f7fbff;
      --accent-soft: rgba(247, 251, 255, 0.11);
      --line: rgba(247, 251, 255, 0.34);
      --shadow: 0 18px 45px rgba(247, 251, 255, 0.14);
      --neon: 0 0 8px rgba(255,255,255,.9), 0 0 22px rgba(220,235,255,.72), 0 0 42px rgba(210,225,245,.42);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Rajdhani", sans-serif;
      background:
        radial-gradient(circle at 10% 0%, rgba(255, 255, 255, 0.1) 0%, transparent 40%),
        radial-gradient(circle at 100% 30%, rgba(210, 225, 245, 0.1) 0%, transparent 40%),
        var(--bg);
      color: var(--ink);
    }
    .page {
      width: 100%;
      max-width: 1120px;
      margin: 0 auto;
      padding: 18px 16px 60px;
      text-align: center;
    }
    .hero {
      position: relative;
      border-radius: 16px;
      overflow: hidden;
      min-height: 90vh;
      box-shadow: var(--shadow);
      margin-bottom: 24px;
      background: #000;
    }
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to top, rgba(0, 0, 0, 0.9), rgba(0, 0, 0, 0.3) 40%, rgba(0, 0, 0, 0.5));
      z-index: 1;
    }
    .hero img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      position: absolute;
      inset: 0;
    }
    .hero-content {
      position: relative;
      z-index: 2;
      color: #fff;
      min-height: 90vh;
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 8px;
      text-align: center;
    }
    .hero-kicker {
      font-family: "Orbitron", sans-serif;
      font-size: 0.85rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      opacity: 0.95;
      color: var(--accent);
      text-shadow: var(--neon);
      transform: translateY(-22px);
    }
    .hero-name {
      font-family: "Orbitron", sans-serif;
      font-weight: 700;
      font-size: clamp(3rem, 12vw, 5rem);
      margin: 0;
      line-height: 1;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .hero-title {
      font-family: "Great Vibes", cursive;
      font-weight: 600;
      font-size: clamp(4.8rem, 17vw, 7.8rem);
      margin: 0;
      opacity: 0.95;
      letter-spacing: 0;
      text-shadow: var(--neon);
      visibility: hidden;
    }
    .fonts-ready .hero-title { visibility: visible; }

    .hero-countdown {
      position: absolute;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 3;
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 4px;
      text-align: center;
    }
    .hero-count-number {
      font-family: "Orbitron", sans-serif;
      font-weight: 700;
      font-size: 2rem;
      color: var(--accent);
      text-shadow: var(--neon);
      line-height: 1;
    }
    .hero-count-separator {
      font-family: "Orbitron", sans-serif;
      font-weight: 700;
      font-size: 2rem;
      color: var(--accent);
      text-shadow: var(--neon);
      line-height: 1;
      opacity: 0.5;
    }

    .grid {
      display: grid;
      gap: 24px;
    }
    .section-card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 12px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .section-inner {
      padding: 40px 28px;
    }
    .section-title {
      font-family: "Orbitron", sans-serif;
      font-weight: 600;
      font-size: 1.65rem;
      margin: 0 0 14px;
      color: var(--ink);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-shadow: var(--neon);
    }
    .section-sub {
      margin: 0 0 16px;
      color: var(--muted);
      font-size: 1.08rem;
      line-height: 1.6;
    }
    .section-divider {
      width: 80px;
      height: 1px;
      background: var(--accent);
      margin: 0 auto 20px auto;
      border-radius: 0.5px;
    }
    .section-icon {
      width: 72px;
      height: 72px;
      margin: 0 auto 22px auto;
      object-fit: contain;
      display: block;
      background: #000;
      border-radius: 50%;
      padding: 8px;
      border: 2px solid var(--accent);
    }

    .info-list {
      display: grid;
      gap: 14px;
      margin-top: 14px;
      color: var(--muted);
      font-size: 1.1rem;
      line-height: 1.65;
      text-align: center;
    }
    .calendar-btn {
      margin-top: 12px;
      border: none;
      background: linear-gradient(90deg, #ffffff, #d8e1ea);
      color: #000;
      border-radius: 6px;
      padding: 11px 16px;
      font-size: 0.78rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      font-family: "Orbitron", sans-serif;
      font-weight: 600;
    }

    .map-wrap {
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid var(--line);
      min-height: 250px;
      background: #111;
    }
    .map-wrap iframe {
      width: 100%;
      height: 250px;
      border: 0;
      display: block;
    }

    .gallery-track {
      display: flex;
      overflow-x: auto;
      gap: 10px;
      padding: 2px 2px 4px;
      scroll-snap-type: x mandatory;
    }
    .gallery-item {
      flex: 0 0 72%;
      border-radius: 8px;
      overflow: hidden;
      border: 3px solid var(--accent);
      box-shadow: 0 12px 32px rgba(247, 251, 255, 0.2);
      cursor: pointer;
      scroll-snap-align: start;
      background: #111;
      aspect-ratio: 4/5;
    }
    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .gift-toggle {
      width: 100%;
      border: 1px solid var(--line);
      background: var(--accent-soft);
      border-radius: 8px;
      color: var(--accent);
      padding: 14px 18px;
      font-weight: 600;
      cursor: pointer;
      text-align: center;
      font-family: "Orbitron", sans-serif;
      letter-spacing: 0.05em;
    }
    .gift-box {
      display: none;
      margin-top: 12px;
      padding: 16px;
      border: 1px solid var(--line);
      border-radius: 8px;
      color: var(--muted);
      font-size: 0.95rem;
      background: #111;
      line-height: 1.6;
      text-align: center;
    }
    .gift-box.visible { display: block; }

    .price-list {
      display: grid;
      gap: 12px;
      max-width: 560px;
      margin: 0 auto;
    }
    .price-row {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,.06);
      border-radius: 8px;
      padding: 14px 16px;
      color: var(--ink);
      font-size: 1.1rem;
    }
    .price-row span:last-child {
      font-family: "Orbitron", sans-serif;
      color: var(--accent);
      text-shadow: var(--neon);
      white-space: nowrap;
    }

    .rsvp-section {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 12px;
      box-shadow: var(--shadow);
      padding: 28px 24px 32px;
    }
    .rsvp-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .rsvp-field label {
      display: block;
      margin-bottom: 5px;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
    }
    .rsvp-field input,
    .rsvp-field select,
    .rsvp-field textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 10px 12px;
      font: inherit;
      font-size: 0.92rem;
      color: var(--ink);
      background: #111;
    }
    .rsvp-field textarea {
      min-height: 72px;
      resize: vertical;
    }
    .full { grid-column: 1 / -1; }
    .send-btn {
      margin-top: 16px;
      width: 100%;
      border: none;
      background: linear-gradient(90deg, #ffffff, #d8e1ea);
      color: #000;
      border-radius: 6px;
      padding: 14px;
      font-size: 0.82rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      cursor: pointer;
      font-weight: 700;
      font-family: "Orbitron", sans-serif;
    }
    .send-btn.is-loading {
      opacity: .78;
      pointer-events: none;
    }
    .rsvp-result {
      display: none;
      border: 1px solid var(--line);
      background: rgba(255,255,255,.07);
      border-radius: 12px;
      padding: 28px 18px;
      color: var(--ink);
    }
    .rsvp-result.visible { display: block; }
    .rsvp-spinner {
      display: inline-block;
      width: 30px;
      height: 30px;
      border: 2px solid rgba(255,255,255,.22);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin .8s linear infinite;
      margin-bottom: 14px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.95);
      z-index: 9999;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .lightbox.visible { display: flex; }
    .lightbox img {
      max-width: 100%;
      max-height: 85vh;
      border-radius: 12px;
      box-shadow: 0 20px 60px rgba(247, 251, 255, 0.24);
    }
    .lightbox-close {
      position: absolute;
      top: 12px;
      right: 14px;
      border: 0;
      background: rgba(247, 251, 255, 0.18);
      color: #fff;
      width: 38px;
      height: 38px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 1.3rem;
    }

    @media (min-width: 900px) {
      .page { 
        padding: 30px 20px 80px; 
        max-width: 100%;
      }
      .hero {
        width: 75%;
        margin: 0 auto;
      }
      .hero, .hero-content { min-height: 85vh; }
      .hero-content { padding: 48px 48px; }
      .hero-countdown {
        bottom: 60px;
        gap: 24px;
      }
      .hero-count-number {
        font-size: 2.5rem;
      }
      .hero-count-separator {
        font-size: 2.5rem;
      }
      .grid {
        grid-template-columns: 1fr;
        gap: 48px;
      }
      .section-card {
        width: 75%;
        margin: 0 auto;
      }
      .section-inner { 
        padding: 52px 48px; 
        text-align: center;
      }
      .section-title {
        font-size: 2rem;
        margin-bottom: 16px;
      }
      .section-sub {
        font-size: 1.2rem;
        margin-bottom: 24px;
      }
      .section-divider {
        width: 100px;
        height: 2px;
        margin: 0 auto 32px auto;
      }
      .info-list {
        font-size: 1.2rem;
        gap: 16px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .gallery-track {
        justify-content: center;
      }
      .gallery-item { 
        flex-basis: 30%; 
        aspect-ratio: 4/5; 
      }
      .gallery-item img { height: 100%; }
      .map-wrap iframe { height: 380px; }
      .rsvp-section { 
        padding: 32px 28px 36px; 
        width: 75%;
        margin: 24px auto 0;
      }
      .rsvp-grid { 
        gap: 24px;
        text-align: center;
      }
      .rsvp-field label {
        font-size: 0.85rem;
        text-align: center;
      }
      .rsvp-field input,
      .rsvp-field select,
      .rsvp-field textarea {
        font-size: 1.05rem;
        padding: 14px 16px;
        text-align: center;
      }
      .send-btn {
        font-size: 0.9rem;
        padding: 16px;
      }
      .price-row {
        font-size: 1.2rem;
      }
    }
  </style>
</head>
<body>
  <%
    const heroImage =
      event.hero_image ||
      "/images/events/isabella-15/hero-disco.webp";
    const galleryImages =
      event.gallery && Array.isArray(event.gallery) && event.gallery.length
        ? event.gallery
        : [
            "/images/events/isabella-15/gallery-01.webp",
            "/images/events/isabella-15/gallery-02.webp",
            "/images/events/isabella-15/gallery-03.webp",
            "/images/events/isabella-15/gallery-04.webp",
            "/images/events/isabella-15/gallery-05.webp",
            "/images/events/isabella-15/gallery-06.webp"
          ];
    const mapsQuery = encodeURIComponent(event.venue_address || event.venue_name || "Buenos Aires");
    const cardPrices = event.custom_data && Array.isArray(event.custom_data.card_prices) ? event.custom_data.card_prices : [];
    const eventDateForCalendar = event.date || "2026-09-05";
    const eventTimeForCalendar = event.time || "21:30";
    const startLocal = new Date(`${eventDateForCalendar}T${eventTimeForCalendar}:00`);
    const endLocal = new Date(startLocal.getTime() + 4 * 60 * 60 * 1000);
    function toGoogleDate(d) {
      const yyyy = d.getUTCFullYear();
      const mm = String(d.getUTCMonth() + 1).padStart(2, "0");
      const dd = String(d.getUTCDate()).padStart(2, "0");
      const hh = String(d.getUTCHours()).padStart(2, "0");
      const mi = String(d.getUTCMinutes()).padStart(2, "0");
      const ss = String(d.getUTCSeconds()).padStart(2, "0");
      return `${yyyy}${mm}${dd}T${hh}${mi}${ss}Z`;
    }
    const googleCalendarUrl =
      "https://calendar.google.com/calendar/render?action=TEMPLATE" +
      `&text=${encodeURIComponent(`Mis 15 - ${event.honorees || "Invitacion"}`)}` +
      `&dates=${toGoogleDate(startLocal)}/${toGoogleDate(endLocal)}` +
      `&details=${encodeURIComponent("Te esperamos para celebrar juntos este dia especial.")}` +
      `&location=${encodeURIComponent(event.venue_address || event.venue_name || "")}`;
    function formatDate(dateStr) {
      if (!dateStr) return "22 de octubre de 2026";
      const date = new Date(dateStr + "T00:00:00");
      const months = ["enero", "febrero", "marzo", "abril", "mayo", "junio", "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"];
      return `${date.getDate()} de ${months[date.getMonth()]} de ${date.getFullYear()}`;
    }
  %>

  <main class="page">
    <header class="hero">
      <img src="<%= heroImage %>" alt="Foto principal del evento" />
      <div class="hero-content">
        <div class="hero-kicker">INVITACION &middot; MIS QUINCE</div>
        <p class="hero-title"><%= event.honorees || "Isabella" %></p>
      </div>
      <div class="hero-countdown" id="hero-countdown" data-date="<%= event.date || "" %>" data-time="<%= event.time || "" %>">
        <div class="hero-count-number" data-unit="days">--</div>
        <span class="hero-count-separator">:</span>
        <div class="hero-count-number" data-unit="hours">--</div>
        <span class="hero-count-separator">:</span>
        <div class="hero-count-number" data-unit="minutes">--</div>
        <span class="hero-count-separator">:</span>
        <div class="hero-count-number" data-unit="seconds">--</div>
      </div>
    </header>

    <section class="grid">
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifDestellos.webp" alt="Destellos" class="section-icon">
          <h2 class="section-title">&iquest;Cu&aacute;ndo?</h2>
          <div class="section-divider"></div>
          <div class="info-list">
            <div><%= formatDate(event.date) %></div>
            <div><%= event.time || "21:30" %> hs</div>
          </div>
          <a class="calendar-btn" href="<%= googleCalendarUrl %>" target="_blank" rel="noopener noreferrer">
            Agregar al calendario
          </a>
        </div>
      </article>

      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifMapa.webp" alt="Mapa" class="section-icon">
          <h2 class="section-title">&iquest;D&oacute;nde?</h2>
          <div class="section-divider"></div>
          <div class="info-list">
            <div><strong>Lugar:</strong> <%= event.venue_name || "Salon de fiestas" %></div>
            <div><strong>Direcci&oacute;n:</strong> <%= event.venue_address || "Direccion del evento" %></div>
          </div>
        </div>
      </article>

      <% if (sections && sections.location) { %>
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifMapa.webp" alt="Mapa" class="section-icon">
          <h2 class="section-title">C&oacute;mo llegar</h2>
          <div class="section-divider"></div>
          <div class="map-wrap">
            <iframe
              title="Mapa del evento"
              src="https://www.google.com/maps?q=<%= mapsQuery %>&output=embed"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      </article>
      <% } %>

      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifRevista.webp" alt="Tarjeta" class="section-icon">
          <h2 class="section-title">Valor de la Tarjeta</h2>
          <div class="section-divider"></div>
          <div class="price-list">
            <% cardPrices.forEach(function(item) { %>
              <div class="price-row">
                <span><%= item.label %></span>
                <span><%= item.value %></span>
              </div>
            <% }) %>
          </div>
        </div>
      </article>

      <% if (sections && sections.dress_code) { %>
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifDiamante.webp" alt="Diamante" class="section-icon">
          <h2 class="section-title">Dress Code</h2>
          <div class="section-divider"></div>
          <div class="info-list">
            <div><strong><%= event.dress_code || "Elegante Sport" %></strong></div>
            <div><%= event.reserved_message || (event.reserved_color ? `El color ${event.reserved_color} se reserva a la cumpleañera` : "") %></div>
          </div>
        </div>
      </article>
      <% } %>

      <% if (sections && sections.gallery) { %>
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifCamara.webp" alt="Camara" class="section-icon">
          <h2 class="section-title">Galer&iacute;a</h2>
          <div class="section-divider"></div>
          <div class="gallery-track">
            <% galleryImages.forEach(function(photo) { %>
              <div class="gallery-item" data-photo="<%= photo %>">
                <img src="<%= photo %>" alt="Foto de galería del evento" />
              </div>
            <% }) %>
          </div>
        </div>
      </article>
      <% } %>

      <article class="section-card">
        <div class="section-inner" style="text-align: center; padding: 32px 24px;">
          <img src="/images/GifStar.webp" alt="Estrella" class="section-icon">
          <div style="border-top: 1px solid var(--line); margin-bottom: 20px;"></div>
          <p style="font-family: 'Rajdhani', sans-serif; font-weight: 500; font-size: 1.15rem; line-height: 1.7; margin: 0 0 20px; color: var(--ink); letter-spacing: 0.03em;">
            <%= event.quote_message || "Como una estrella en el cielo, me detendré en cada luna a recordar mi niñez, para que ese brillo especial nunca se pierda en la inmensidad del universo." %>
          </p>
          <div style="border-bottom: 1px solid var(--line);"></div>
        </div>
      </article>

      <% if (sections && sections.gifts) { %>
      <article class="section-card">
        <div class="section-inner">
          <img src="/images/GifRegalo.webp" alt="Regalo" class="section-icon">
          <h2 class="section-title">Regalo</h2>
          <div class="section-divider"></div>
          <p class="section-sub"><%= event.gift_message || "Con tu presencia alcanza, pero si deseas hacerme un regalo será recibido con mucho amor." %></p>
        </div>
      </article>
      <% } %>

    </section>

    <section class="rsvp-section" style="margin-top:16px;">
      <h2 class="section-title">Confirmar asistencia</h2>
      <div class="section-divider"></div>
      <p class="section-sub">&iexcl;Quiero saber si vas a estar! Complet&aacute; tus datos ac&aacute; abajo.</p>
      <form action="/api/<%= event.slug %>/rsvp" method="post" id="rsvp-form">
        <div class="rsvp-grid">
          <div class="rsvp-field full">
            <label for="contact_name">Nombre de quien confirma</label>
            <input type="text" id="contact_name" name="contact_name" required>
          </div>
          <div class="rsvp-field">
            <label for="people_count">&iquest;Cu&aacute;ntos vienen?</label>
            <input type="number" id="people_count" name="people_count" min="1" value="1" required>
          </div>
          <div class="rsvp-field">
            <label for="status">Asistencia</label>
            <select id="status" name="status">
              <option value="confirmed">Voy / Vamos</option>
              <option value="declined">No puedo ir</option>
            </select>
          </div>
          <div class="rsvp-field full">
            <label for="people_names">Nombre y apellido de todos los que te acompa&ntilde;an</label>
            <textarea id="people_names" name="people_names" placeholder="Ej: Juan Perez, Ana Gomez, Sofia Lopez"></textarea>
          </div>
          <div class="rsvp-field full">
            <label for="food_preferences">Preferencias de comida</label>
            <textarea id="food_preferences" name="food_preferences" placeholder="Aclaraciones sobre comida"></textarea>
          </div>
          <% if (sections && sections.music) { %>
            <div class="rsvp-field full">
              <label for="song_suggestions">Temas que no pueden faltar</label>
              <textarea id="song_suggestions" name="song_suggestions" placeholder="Decime que canciones queres bailar"></textarea>
            </div>
          <% } %>
          <div class="rsvp-field full">
            <label for="comments">Mensajito para m&iacute;</label>
            <textarea id="comments" name="comments"></textarea>
          </div>
        </div>
        <button type="submit" class="send-btn">Enviar confirmaci&oacute;n</button>
      </form>
      <div class="rsvp-result" id="rsvp-result" aria-live="polite"></div>
    </section>
  </main>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close" aria-label="Cerrar">×</button>
    <img src="" alt="Foto ampliada de la galería" id="lightbox-image" />
  </div>

  <script>
    (function() {
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(function() { document.documentElement.classList.add("fonts-ready"); });
      } else {
        document.documentElement.classList.add("fonts-ready");
      }

      const qs = new URLSearchParams(window.location.search);
      if (qs.get("rsvp") === "ok") {
        qs.delete("rsvp");
        const clean = window.location.pathname + (qs.toString() ? "?" + qs.toString() : "");
        window.history.replaceState({}, "", clean);
        showRsvpResult(false);
      }

      const el = document.getElementById("hero-countdown");
      if (el) {
        const dateStr = el.getAttribute("data-date");
        const timeStr = el.getAttribute("data-time") || "00:00";
        if (dateStr) {
          const target = new Date(dateStr + "T" + timeStr + ":00");
          function update() {
            const now = new Date();
            let diff = target.getTime() - now.getTime();
            if (diff < 0) diff = 0;
            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
            const minutes = Math.floor((diff / (1000 * 60)) % 60);
            const seconds = Math.floor((diff / 1000) % 60);
            const set = (unit, value) => {
              const node = el.querySelector('[data-unit="' + unit + '"]');
              if (node) node.textContent = String(value).padStart(2, "0");
            };
            set("days", days);
            set("hours", hours);
            set("minutes", minutes);
            set("seconds", seconds);
          }
          update();
          setInterval(update, 1000);
        }
      }

      const rsvpForm = document.getElementById("rsvp-form");
      const rsvpResult = document.getElementById("rsvp-result");
      const sendBtn = rsvpForm ? rsvpForm.querySelector(".send-btn") : null;
      function showRsvpResult(loading) {
        if (!rsvpForm || !rsvpResult) return;
        rsvpForm.style.display = "none";
        rsvpResult.classList.add("visible");
        rsvpResult.innerHTML = loading
          ? '<span class="rsvp-spinner"></span><p class="section-sub" style="margin:0;">Enviando confirmacion...</p>'
          : '<h3 class="section-title" style="font-size:1.35rem;margin-bottom:10px;">Gracias por confirmar</h3><p class="section-sub" style="margin:0;">&iexcl;La vamos a pasar muy bien!</p>';
      }
      if (rsvpForm) {
        rsvpForm.addEventListener("submit", async function(e) {
          e.preventDefault();
          if (sendBtn) sendBtn.classList.add("is-loading");
          showRsvpResult(true);
          try {
            const response = await fetch(rsvpForm.action, {
              method: "POST",
              body: new URLSearchParams(new FormData(rsvpForm)),
              headers: { "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8" },
            });
            if (!response.ok) throw new Error("No se pudo enviar");
            setTimeout(function() { showRsvpResult(false); }, 900);
          } catch (error) {
            rsvpForm.style.display = "";
            rsvpResult.classList.remove("visible");
            rsvpResult.innerHTML = "";
            if (sendBtn) sendBtn.classList.remove("is-loading");
            window.alert("No pudimos enviar la confirmacion. Intentá nuevamente.");
          }
        });
      }

      const lightbox = document.getElementById("lightbox");
      const lightboxImage = document.getElementById("lightbox-image");
      const lightboxClose = document.getElementById("lightbox-close");
      document.querySelectorAll(".gallery-item").forEach(function(item) {
        item.addEventListener("click", function() {
          const photo = item.getAttribute("data-photo");
          if (!photo || !lightbox || !lightboxImage) return;
          lightboxImage.src = photo;
          lightbox.classList.add("visible");
        });
      });
      if (lightboxClose && lightbox) {
        lightboxClose.addEventListener("click", function() {
          lightbox.classList.remove("visible");
        });
        lightbox.addEventListener("click", function(e) {
          if (e.target === lightbox) lightbox.classList.remove("visible");
        });
      }
    })();
  </script>
</body>
</html>

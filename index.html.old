              <div class="gallery-mock-date">Sus 15 · 22 · X</div>
              <div class="gallery-mock-detail" style="margin-top:12px;font-style:italic;font-size:0.8rem;">"Brillando con luz propia"</div>
              <span class="gallery-label">VER DEMO</span>

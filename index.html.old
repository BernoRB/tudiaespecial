        <div class="carousel-item">
          <div class="gallery-item">
            <div class="gallery-mock gallery-mock-quinces">
              <div class="gallery-mock-ornament">🌹</div>
              <div class="gallery-mock-title">Quinces Velvet</div>
              <div class="gallery-mock-line" style="background:linear-gradient(90deg,#8b1a3c,#a02050);"></div>
              <div class="gallery-mock-date">Mis 15 · 05 · XII</div>
              <div class="gallery-mock-detail" style="margin-top:12px;font-style:italic;font-size:0.8rem;">"Libre como mariposa"</div>
              <span class="gallery-label">VER DEMO</span>
            </div>

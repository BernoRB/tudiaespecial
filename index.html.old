<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>TuDiaEspecial – Invitaciones Digitales Premium</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="css/styles.css">
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">TuDia<span>Especial</span></div>
  <a href="#plan" class="nav-cta">Ver planes</a>
</nav>

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero-bg-pattern"></div>
  <!-- ACÁ PONÉ LA FOTO DEL HERO -->
  <div class="hero-image">
    <img src="images/hero-photo.jpg" alt="Invitación digital elegante">
  </div>
  <div class="hero-inner">
    <div class="hero-kicker reveal">Bodas · Quinces · Bautismos · Eventos</div>
    <h1 class="reveal reveal-delay-1">
      Tu evento comienza<br/>con <em>un click,</em><br/>no con un sobre
    </h1>
    <p class="hero-sub reveal reveal-delay-2">Invitaciones digitales interactivas para las celebraciones que importan. Elegancia, rapidez y confirmación en tiempo real.</p>
    <div class="hero-buttons reveal reveal-delay-3">
      <a href="#galeria" class="btn-primary">Ver Catálogo</a>
      <a href="#plan" class="btn-secondary">Ver Planes</a>
    </div>
    <div class="hero-scroll reveal reveal-delay-4">
      <span>Deslizá</span>
      <div class="scroll-line"></div>
    </div>
  </div>
</section>

<!-- POR QUÉ DIGITAL -->
<section id="por-que">
  <div class="section-header reveal">
    <span class="section-label">La diferencia</span>
    <h2 class="section-title">¿Por qué digital?</h2>
    <p class="section-sub">Elegante, sustentable y pensado para el mundo en que vivimos.</p>
  </div>

  <div class="divider reveal">
    <div class="divider-line"></div>
    <span class="divider-ornament">✦</span>
    <div class="divider-line"></div>
  </div>

  <div class="cards-grid">
    <div class="card reveal reveal-delay-1">
      <div class="card-icon">
        <svg viewBox="0 0 24 24"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M7 9l5 5 5-5" stroke-linecap="round"/></svg>
      </div>
      <h3>Eco-Friendly</h3>
      <p>Sin papel, sin residuos. Tu invitación llega al instante y cuida el planeta. Cero impresiones, cero embalaje.</p>
    </div>
    <div class="card reveal reveal-delay-2">
      <div class="card-icon">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2" stroke-linecap="round"/></svg>
      </div>
      <h3>Confirmación Instantánea</h3>
      <p>Lista de invitados actualizada al segundo. Sabés en tiempo real quién confirma, sin llamadas ni hojas de cálculo.</p>
    </div>
    <div class="card reveal reveal-delay-3">
      <div class="card-icon">
        <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </div>
      <h3>Interactividad Total</h3>
      <p>Ubicación con GPS, playlist de Spotify, cuenta regresiva animada y galería de fotos. Una experiencia, no un papel.</p>
    </div>
  </div>
</section>

<!-- PLAN -->
<section id="plan">
  <div class="section-header reveal">
    <span class="section-label">La propuesta</span>
    <h2 class="section-title">Un plan.<br/>Todo incluido.</h2>
    <p class="section-sub">Sin sorpresas, sin costos ocultos. Todo lo que necesitás para que tu evento brille desde el primer mensaje.</p>
  </div>

  <div class="plan-wrapper">
    <div class="plan-card reveal">
      <span class="plan-badge">✦ Más elegido</span>
      <div class="plan-name">Full Experience</div>
      <div class="plan-price-row">
        <span class="plan-currency">$</span>
        <span class="plan-price">25.000</span>
        <span class="plan-period">· pago único</span>
      </div>
      <p style="color:rgba(245,239,199,0.5);font-size:0.85rem;margin-bottom:0;">Entrega en <strong style="color:var(--gold)">24hs hábiles</strong> desde el envío de tus datos.</p>
      <a href="https://wa.me/?text=Hola!%20Quiero%20hacer%20mi%20invitación%20digital" class="plan-cta" target="_blank" style="background:var(--gold);color:var(--ink);margin-bottom:12px;">
        LO QUIERO! (seña 50%)
      </a>
      <a href="https://wa.me/?text=Hola!%20Quiero%20info%20sobre%20invitaciones%20digitales" class="plan-cta" target="_blank" style="background:transparent;color:rgba(245,239,199,0.8);border:2px solid rgba(245,239,199,0.3);">
        CONSULTAR POR WHATSAPP
      </a>
    </div>

    <div class="reveal reveal-delay-1">
      <p class="plan-features-title">Todo lo que incluye:</p>
      <ul class="plan-features">
        <li><span class="check-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>Diseño 100% adaptado a celulares y computadores</li>
        <li><span class="check-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>Confirmación de asistencia online</li>
        <li><span class="check-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>Recopilación de datos del invitado (alimentación, mensajes, etc)</li>
        <li><span class="check-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>Listado de confirmados en tiempo real</li>
        <li><span class="check-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>Cuenta regresiva animada</li>
        <li><span class="check-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>Ubicación y mapas</li>
        <li><span class="check-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>Dress Code</li>
        <li><span class="check-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>Canciones sugeridas</li>
        <li><span class="check-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>Galería de fotos</li>
        <li><span class="check-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>Sección de regalos con CBU/Alias</li>
        <li><span class="check-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>Música de fondo opcional</li>
        <li><span class="check-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>Botón "Agendar al Calendario"</li>
        <li><span class="check-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>Entrega en 24hs hábiles garantizada</li>
      </ul>
    </div>
  </div>
</section>

<!-- GALERÍA -->
<section id="galeria">
  <div class="section-header reveal">
    <span class="section-label">El catálogo</span>
    <h2 class="section-title">Plantillas con personalidad</h2>
